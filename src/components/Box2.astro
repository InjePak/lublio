---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";

const { title, subtitle, description, language } = Astro.props;

const colorMap: Record<string, string> = {
  eng: "var(--pink400)",
  fra: "var(--sky400)",
  deu: "var(--amber400)",
  rus: "var(--indigo400)",
};
const color = colorMap[language] || "var(--zinc400)";
---

<style define:vars={{ color }}>
  .box {
    background-color: var(--color);
  }
</style>

<div class="box fade_1">
  <h2 class="riseUp_2">{title}</h2>
  <h3 class="riseUp_3">{subtitle}</h3>
  <div class="item">
    <i class="loader"></i>
  </div>
  <p class="riseUp_4">{description}</p>
</div>

<style>
  .box {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    max-height: 300px;
    padding: 1.5rem;
    margin-bottom: 3rem;
    outline: none;
    z-index: 0;
    text-decoration: none;
    transition: all 1s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .box > h2 {
    position: relative;
    display: block;
    width: calc(100% - 40px);
    font-size: 40px;
    font-weight: 600;
    line-height: 1.2;
    word-break: keep-all;
    word-wrap: break-word;
    margin-bottom: 10px;
    transition: all 0.4s;
  }

  .box > h3 {
    position: relative;
    display: block;
    font-size: 20px;
    font-weight: 500;
    letter-spacing: 0px;
    line-height: 1;
    margin-top: 5px;
    transition: all 0.4s;
  }

  .box > p {
    position: absolute;
    width: calc(100% - 3rem);
    left: 1.5rem;
    bottom: 1.5rem;
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0px;
    line-height: 1.4;
    transition: all 0.4s;
  }

  .box > p:last-child {
    margin-bottom: 0px;
  }

  .box > h2,
  .box > h3,
  .box > h4,
  .box > span,
  .box > p {
    color: var(--zinc800);
  }

  /* Moving Item */

  .box .item {
    position: absolute;
    display: grid;
    top: 2rem;
    right: 2rem;
    place-items: center;
    transition: all 0.4s ease;
  }

  .box .loader {
    display: block;
    position: relative;
    width: 50%;
    display: grid;
    place-items: center;
    cursor: default;
  }

  .box .loader::before,
  .box .loader::after {
    content: "";
    box-sizing: border-box;
    position: absolute;
    width: 10px;
    height: 10px;
  }

  .box .loader::before,
  .box .loader::after {
    background-color: var(--zinc200);
  }

  .box .loader::before {
    top: calc(50% - 10px);
    left: calc(50% - 10px);
    animation: loader1 2.4s cubic-bezier(0, 0, 0.24, 1.21) infinite;
  }

  .box .loader::after {
    top: 50%;
    left: 50%;
    animation: loader2 2.4s cubic-bezier(0, 0, 0.24, 1.21) infinite;
  }

  @keyframes loader1 {
    0%,
    100% {
      transform: none;
    }

    25% {
      transform: translateX(100%);
    }

    50% {
      transform: translateX(100%) translateY(100%);
    }

    75% {
      transform: translateY(100%);
    }
  }

  @keyframes loader2 {
    0%,
    100% {
      transform: none;
    }

    25% {
      transform: translateX(-100%);
    }

    50% {
      transform: translateX(-100%) translateY(-100%);
    }

    75% {
      transform: translateY(-100%);
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .box > h2 {
      font-size: 32px;
    }

    .box > h3 {
      font-size: 18px;
    }

    .box > p {
      font-size: 14px;
      line-height: 1.3;
    }
  }
</style>
