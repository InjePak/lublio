---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";

const { language, level } = Astro.props;

const colorMap700: Record<string, string> = {
  fra: "rgba(3, 105, 161, 0.2)",
  rus: "rgba(67, 56, 202, 0.2)",
  heb: "rgba(29, 78, 216, 0.2)",
  kaz: "rgba(15, 118, 110, 0.2)",
};
const colorMap400: Record<string, string> = {
  fra: "rgba(56, 189, 248, 0.7)",
  rus: "rgba(129, 140, 248, 0.7)",
  heb: "rgba(96, 165, 250, 0.7)",
  kaz: "rgba(45, 212, 191, 0.7)",
};
const color700 = colorMap700[language] || "var(--zinc700)";
const color400 = colorMap400[language] || "var(--zinc400)";

let colorLightest = color400;
let colorDarkest = color700;
---

<style define:vars={{ colorLightest, colorDarkest }}>
  .cube > div > span {
    background: linear-gradient(var(--colorDarkest), var(--colorLightest));
  }

  .top {
    background-color: var(--colorDarkest);
  }

  .top::before {
    background-color: var(--colorLightest);
    box-shadow:
      0 0 120px var(--colorLightest);
      0 0 200px var(--colorLightest);
  }

  .bottom {
    background-color: var(--colorLightest);
  }
</style>

<div class="cube">
  <div class="top"></div>
  <div>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
  </div>
  <div class="bottom"></div>
</div>

<style>
  .cube {
    position: relative;
    width: 150px;
    height: 150px;
    margin: 100px auto;
    transform-style: preserve-3d;
    transform: rotateX(-30deg);
    animation: animate 3s linear infinite;
  }

  @keyframes animate {
    0% {
      transform: rotateX(-20deg) rotateY(0deg);
    }
    100% {
      transform: rotateX(-20deg) rotateY(360deg);
    }
  }

  .cube > div {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
  }

  .cube > div > span {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .cube > div > span:nth-child(1) {
    transform: rotateY(calc(90deg * 0)) translateZ(75px);
  }

  .cube > div > span:nth-child(2) {
    transform: rotateY(calc(90deg * 1)) translateZ(75px);
  }

  .cube > div > span:nth-child(3) {
    transform: rotateY(calc(90deg * 2)) translateZ(75px);
  }

  .cube > div > span:nth-child(4) {
    transform: rotateY(calc(90deg * 3)) translateZ(75px);
  }

  .top {
    position: absolute;
    top: 0;
    left: 0;
    width: 150px;
    height: 150px;
    transform: rotateX(90deg) translateZ(75px);
  }

  .bottom {
    position: absolute;
    top: 0;
    left: 0;
    width: 150px;
    height: 150px;
    transform: rotateX(90deg) translateZ(-75px);
  }

  .top::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 150px;
    height: 150px;
    transform: translateZ(-200px);
    filter: blur(20px);
  }
</style>
