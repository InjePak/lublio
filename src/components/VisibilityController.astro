---
const { items } = Astro.props;
---

<>
  <div class="controller">
    {
      items.map((item: any) => (
        <label>
          <input
            type="checkbox"
            class="visibility-toggle"
            data-target={item.id}
            checked
          />
          <span>{item.label}</span>
        </label>
      ))
    }
  </div>
</>

<style>
  .controller {
    display: flex;
    justify-content: space-evenly;
    top: 0;
    border: 1px solid var(--zinc400);
    background-color: var(--zinc700);
    padding: 0.5rem 1rem;
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  /* label이 4개 이상일 때 적용되는 스타일 */
  .controller:has(label:nth-last-child(n + 4)) {
    display: grid; /* Grid로 변경 */
    grid-template-columns: 1fr 1fr; /* 1:1 비율로 2열 배치 */
    border-radius: 20px; /* 2줄이 되면 캡슐형보다는 약간 각진 게 예쁩니다 */
    justify-items: center; /* 아이템들을 왼쪽 정렬 (취향껏 선택) */
    padding: 1rem;
  }

  .controller label {
    cursor: pointer;
    font-size: 1rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .visibility-toggle {
    display: none;
  }

  .visibility-toggle + span {
    display: inline-block;
    padding: 8px 16px;
    font-weight: 600;
    font-size: 18px;
    cursor: pointer;
    font-family: "Roboto Condensed", sans-serif;
    text-transform: uppercase;
    transition: all 0.2s ease;
  }

  .visibility-toggle:not(:checked) + span {
    color: var(--zinc500);
  }

  .visibility-toggle:not(:checked) + span:hover,
  .visibility-toggle:checked + span:hover {
    background-color: var(--zinc600);
  }

  .visibility-toggle:checked + span {
    color: var(--zinc200);
  }
</style>

<script>
  // 페이지 내의 모든 체크박스를 가져옵니다.
  const toggles = document.querySelectorAll(".visibility-toggle");

  toggles.forEach((toggle) => {
    toggle.addEventListener("change", (e) => {
      const targetClass = (e.target as HTMLInputElement).dataset.target;
      const isVisible = (e.target as HTMLInputElement).checked;

      // 해당 클래스를 가진 모든 요소를 찾아 숨기거나 보입니다.
      const elements = document.querySelectorAll(`.${targetClass}`);
      elements.forEach((el) => {
        (el as HTMLElement).style.display = isVisible ? "block" : "none";
      });
    });
  });
</script>
