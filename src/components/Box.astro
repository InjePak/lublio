---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";

const { title, subtitle, description, language } = Astro.props;

const colorMap1: Record<string, string> = {
  eng: "var(--pink500)",
  fra: "var(--sky500)",
  deu: "var(--amber500)",
  ita: "var(--emerald500)",
  esp: "var(--orange500)",
  rus: "var(--indigo500)",
  tur: "var(--rose500)",
  ces: "var(--blue500)",
  hun: "var(--lime500)",
};
const colorMap2: Record<string, string> = {
  eng: "var(--pink400)",
  fra: "var(--sky400)",
  deu: "var(--amber400)",
  ita: "var(--emerald400)",
  esp: "var(--orange400)",
  rus: "var(--indigo400)",
  tur: "var(--rose400)",
  ces: "var(--blue400)",
  hun: "var(--lime400)",
};
const colorMap3: Record<string, string> = {
  eng: "var(--pink300)",
  fra: "var(--sky300)",
  deu: "var(--amber300)",
  ita: "var(--emerald300)",
  esp: "var(--orange300)",
  rus: "var(--indigo300)",
  tur: "var(--rose300)",
  ces: "var(--blue300)",
  hun: "var(--lime300)",
};
const colorMap4: Record<string, string> = {
  eng: "var(--pink200)",
  fra: "var(--sky200)",
  deu: "var(--amber200)",
  ita: "var(--emerald200)",
  esp: "var(--orange200)",
  rus: "var(--indigo200)",
  tur: "var(--rose200)",
  ces: "var(--blue200)",
  hun: "var(--lime200)",
};
const colorMap5: Record<string, string> = {
  eng: "var(--pink100)",
  fra: "var(--sky100)",
  deu: "var(--amber100)",
  ita: "var(--emerald100)",
  esp: "var(--orange100)",
  rus: "var(--indigo100)",
  tur: "var(--rose100)",
  ces: "var(--blue100)",
  hun: "var(--lime100)",
};
const color500 = colorMap1[language] || "var(--zinc500)";
const color400 = colorMap2[language] || "var(--zinc400)";
const color300 = colorMap3[language] || "var(--zinc300)";
const color200 = colorMap4[language] || "var(--zinc200)";
const color100 = colorMap5[language] || "var(--zinc100)";
---

<style define:vars={{ color500, color400, color300, color200, color100 }}>
  .box {
    background-color: transparent;
  }

  .box > h2,
  .box > h3,
  .box > p {
    color: var(--zinc800);
  }

  .box > h2::after {
    background-color: var(--color400);
  }

  .box .loader::before,
  .box .loader::after {
    background-color: var(--color400);
  }
</style>

<div class="box riseUp_1">
  <h2 class="riseUp_2">{title}</h2>
  <h3 class="riseUp_3">{subtitle}</h3>
  <div class="item">
    <i class="loader"></i>
  </div>
  <p class="riseUp_4">{description}</p>
</div>

<style>
  .box {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    max-height: 300px;
    margin-bottom: 2rem;
    outline: none;
    z-index: 0;
    text-decoration: none;
    transition: all 1s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .box > h2 {
    position: relative;
    font-family: "Roboto Condensed", sans-serif;
    text-transform: uppercase;
    display: inline;
    font-size: 60px;
    font-weight: 600;
    line-height: 1;
    word-break: keep-all;
    word-wrap: break-word;
    transition: all 0.4s;
  }

  .box > h2::after {
    content: "";
    position: absolute;
    width: 100%;
    height: 15px;
    bottom: 10px;
    left: 0;
    opacity: 0.8;
    z-index: -1;
    transform-origin: bottom left;
    animation: underline 2.4s cubic-bezier(0, 0, 0.24, 1.21);
  }

  @keyframes underline {
    0% {
      transform: scaleX(0);
    }

    100% {
      transform: scaleX(1);
    }
  }

  .box > h3 {
    position: relative;
    display: block;
    font-size: 28px;
    font-weight: 600;
    letter-spacing: 0px;
    line-height: 1;
    margin-top: 10px;
    transition: all 0.4s;
  }

  .box > p {
    position: absolute;
    width: 100%;
    left: 0rem;
    bottom: 0rem;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0px;
    line-height: 1.4;
    transition: all 0.4s;
  }

  .box > p:last-child {
    margin-bottom: 0px;
  }

  .box > h2,
  .box > h3,
  .box > h4,
  .box > span,
  .box > p {
    color: var(--zinc800);
  }

  /* Moving Item */

  .box .item {
    position: absolute;
    display: grid;
    top: 1rem;
    right: 1rem;
    place-items: center;
    transition: all 0.4s ease;
  }

  .box .loader {
    display: block;
    position: relative;
    width: 50%;
    display: grid;
    place-items: center;
    cursor: default;
  }

  .box .loader::before,
  .box .loader::after {
    content: "";
    box-sizing: border-box;
    position: absolute;
    width: 10px;
    height: 10px;
  }

  .box .loader::before,
  .box .loader::after {
    background-color: var(--zinc400);
  }

  .box .loader::before {
    top: calc(50% - 10px);
    left: calc(50% - 10px);
    animation: loader1 2.4s cubic-bezier(0, 0, 0.24, 1.21) infinite;
  }

  .box .loader::after {
    top: 50%;
    left: 50%;
    animation: loader2 2.4s cubic-bezier(0, 0, 0.24, 1.21) infinite;
  }

  @keyframes loader1 {
    0%,
    100% {
      transform: none;
    }

    25% {
      transform: translateX(100%);
    }

    50% {
      transform: translateX(100%) translateY(100%);
    }

    75% {
      transform: translateY(100%);
    }
  }

  @keyframes loader2 {
    0%,
    100% {
      transform: none;
    }

    25% {
      transform: translateX(-100%);
    }

    50% {
      transform: translateX(-100%) translateY(-100%);
    }

    75% {
      transform: translateY(-100%);
    }
  }

  /* Mobile */
  @media (max-width: 480px) {
    .box {
      max-height: 300px;
    }

    .box > h2 {
      font-size: 50px;
    }

    .box > h3 {
      font-size: 24px;
    }

    .box > p {
      font-size: 14px;
    }
  }
</style>
