---
// Logo
import LogoSVG from "../../public/lublio-logo-light.svg?raw";
---

<div class="icon-wrapper">
  <a href="/">
    <Fragment set:html={LogoSVG} />
  </a>
</div>
<h1>Not available on mobile</h1>
<h2>현재 루블리오는 데스크탑에서만 이용 가능합니다</h2>

<style>
  .icon-wrapper {
    position: absolute;
    width: 60px; /* 원하는 크기 조절 */
    top: 40%;
    left: 50%;
    padding-top: 10px;
    padding-left: 10px;
    padding-right: 10px;
    padding-bottom: 5px;
    transform: translate(-50%, -50%);
    transition: 0.4s all;
  }

  /* SVG 내부의 path나 circle 등을 직접 제어 */
  .icon-wrapper :global(svg) {
    width: 100%;
    height: 100%;
  }

  /* 호버 시 색상 변경 예시 */
  .icon-wrapper:hover {
    cursor: pointer;
    background-color: var(--neutral200);
  }

  h1 {
    position: absolute;
    font-family: "Inter", sans-serif;
    display: block;
    text-align: center;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 36px;
    line-height: 60px;
  }

  h2 {
    position: absolute;
    font-family: "Noto Korean", sans-serif;
    display: block;
    text-align: center;
    top: 56%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 20px;
    font-weight: 600;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .icon-wrapper {
      top: 43%;
    }

    h1 {
      font-size: 28px;
    }

    h2 {
      font-size: 16px;
      top: 54%;
    }
  }
</style>
