---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";

const { id, title, subtitle, language, path } = Astro.props;

const colorMap1: Record<string, string> = {
  eng: "var(--pink500)",
  fra: "var(--blue500)",
  deu: "var(--amber500)",
  ita: "var(--emerald500)",
  swe: "var(--cyan500)",
  spa: "var(--rose500)",
  nld: "var(--orange500)",
  hun: "var(--lime500)",
};
const colorMap2: Record<string, string> = {
  eng: "var(--pink400)",
  fra: "var(--blue400)",
  deu: "var(--amber400)",
  ita: "var(--emerald400)",
  swe: "var(--cyan400)",
  spa: "var(--rose400)",
  nld: "var(--orange400)",
  hun: "var(--lime400)",
};
const colorMap3: Record<string, string> = {
  eng: "var(--pink300)",
  fra: "var(--blue300)",
  deu: "var(--amber300)",
  ita: "var(--emerald300)",
  swe: "var(--cyan300)",
  spa: "var(--rose300)",
  nld: "var(--orange300)",
  hun: "var(--lime300)",
};
const colorMap4: Record<string, string> = {
  eng: "var(--pink200)",
  fra: "var(--blue200)",
  deu: "var(--amber200)",
  ita: "var(--emerald200)",
  swe: "var(--cyan200)",
  spa: "var(--rose200)",
  nld: "var(--orange200)",
  hun: "var(--lime200)",
};
const colorMap5: Record<string, string> = {
  eng: "var(--pink100)",
  fra: "var(--blue100)",
  deu: "var(--amber100)",
  ita: "var(--emerald100)",
  swe: "var(--cyan100)",
  spa: "var(--rose100)",
  nld: "var(--orange100)",
  hun: "var(--lime100)",
};
const color500 = colorMap1[language] || "var(--neutral500)";
const color400 = colorMap2[language] || "var(--neutral400)";
const color300 = colorMap3[language] || "var(--neutral300)";
const color200 = colorMap4[language] || "var(--neutral200)";
const color100 = colorMap5[language] || "var(--neutral100)";
---

<style define:vars={{ color500, color400, color300, color200, color100 }}>
  .btn:hover {
    padding-left: 25px;
    border-left: 4px solid var(--color500);
    background-color: var(--color100);
  }

  .btn:hover > h1,
  .btn:hover > h2 {
    color: var(--color500);
  }
</style>

<a href={path}>
  <div class="btn">
    <h1>{id}. {title}</h1>
    <h2>{subtitle}</h2>
  </div>
</a>

<style>
  .btn {
    position: relative;
    border-left: 4px solid var(--neutral200);
    background-color: var(--neutral200);
    padding: 1rem;
    margin-bottom: 1.5rem;
    transition: all 0.4s;
  }

  .btn > h1 {
    position: relative;
    font-family: "Roboto Condensed", sans-serif;
    text-transform: uppercase;
    font-size: 28px;
    font-weight: 600;
    margin-bottom: 0.5rem;
    transition: 0.4s all;
  }

  .btn > h2 {
    position: relative;
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 0rem;
    color: var(--zinc500);
    transition: 0.4s all;
  }

  .btn > p {
    position: absolute;
    left: 1.5rem;
    bottom: 0;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .btn {
      margin-bottom: 20px;
    }

    .btn > h1 {
      font-size: 20px;
    }

    .btn > h2 {
      font-size: 14px;
    }
  }
</style>
