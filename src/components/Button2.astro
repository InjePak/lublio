---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";

const { id, title, subtitle, language, path } = Astro.props;

const colorMap800: Record<string, string> = {
  eng: "var(--pink800)",
  fra: "var(--sky800)",
  deu: "var(--amber800)",
  ita: "var(--emerald800)",
  tur: "var(--rose800)",
  rus: "var(--indigo800)",
  heb: "var(--blue800)",
  kaz: "var(--cyan800)",
};
const colorMap700: Record<string, string> = {
  eng: "var(--pink700)",
  fra: "var(--sky700)",
  deu: "var(--amber700)",
  ita: "var(--emerald700)",
  tur: "var(--rose700)",
  rus: "var(--indigo700)",
  heb: "var(--blue700)",
  kaz: "var(--cyan700)",
};
const colorMap600: Record<string, string> = {
  eng: "var(--pink600)",
  fra: "var(--sky600)",
  deu: "var(--amber600)",
  ita: "var(--emerald600)",
  tur: "var(--rose600)",
  rus: "var(--indigo600)",
  heb: "var(--blue600)",
  kaz: "var(--cyan600)",
};
const colorMap500: Record<string, string> = {
  eng: "var(--pink500)",
  fra: "var(--sky500)",
  deu: "var(--amber500)",
  ita: "var(--emerald500)",
  tur: "var(--rose500)",
  rus: "var(--indigo500)",
  heb: "var(--blue500)",
  kaz: "var(--cyan500)",
};
const colorMap400: Record<string, string> = {
  eng: "var(--pink400)",
  fra: "var(--sky400)",
  deu: "var(--amber400)",
  ita: "var(--emerald400)",
  tur: "var(--rose400)",
  rus: "var(--indigo400)",
  heb: "var(--blue400)",
  kaz: "var(--cyan400)",
};
const colorMap300: Record<string, string> = {
  eng: "var(--pink300)",
  fra: "var(--sky300)",
  deu: "var(--amber300)",
  ita: "var(--emerald300)",
  tur: "var(--rose300)",
  rus: "var(--indigo300)",
  heb: "var(--blue300)",
  kaz: "var(--cyan300)",
};
const colorMap200: Record<string, string> = {
  eng: "var(--pink200)",
  fra: "var(--sky200)",
  deu: "var(--amber200)",
  ita: "var(--emerald200)",
  tur: "var(--rose200)",
  rus: "var(--indigo200)",
  heb: "var(--blue200)",
  kaz: "var(--cyan200)",
};
const colorMap100: Record<string, string> = {
  eng: "var(--pink100)",
  fra: "var(--sky100)",
  deu: "var(--amber100)",
  ita: "var(--emerald100)",
  tur: "var(--rose100)",
  rus: "var(--indigo100)",
  heb: "var(--blue100)",
  kaz: "var(--cyan100)",
};
const color800 = colorMap800[language] || "var(--neutral800)";
const color700 = colorMap700[language] || "var(--neutral700)";
const color600 = colorMap600[language] || "var(--neutral600)";
const color500 = colorMap500[language] || "var(--neutral500)";
const color400 = colorMap400[language] || "var(--neutral400)";
const color300 = colorMap300[language] || "var(--neutral300)";
const color200 = colorMap200[language] || "var(--neutral200)";
const color100 = colorMap100[language] || "var(--neutral100)";
---

<style define:vars={{ color500, color400, color300, color200, color100 }}>
  .btn:hover {
    background: var(--neutral200);
  }
</style>

<a href={path}>
  <div class="btn">
    <h1>{id}. {title}</h1>
    <h2>{subtitle}</h2>
  </div>
</a>

<style>
  .btn {
    position: relative;
    background-color: transparent;
    padding: 1.5rem;
    transition: all 0.4s;
    border: 1px solid var(--neutral400);
    border-radius: 15px;
  }

  .btn > h1 {
    position: relative;
    font-family: "Noto Korean", sans-serif;
    text-transform: uppercase;
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 0.5rem;
    transition: 0.4s all;
  }

  .btn > h2 {
    position: relative;
    font-family: "Inter", "Noto Hebrew", sans-serif;
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 0rem;
    color: var(--neutral500);
    transition: 0.4s all;
  }

  .btn > p {
    position: absolute;
    left: 1.5rem;
    bottom: 0;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .btn {
      margin-bottom: 20px;
    }

    .btn > h1 {
      font-size: 20px;
    }

    .btn > h2 {
      font-size: 14px;
    }
  }
</style>
