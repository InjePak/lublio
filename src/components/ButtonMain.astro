---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";

interface Props {
  title: string;
  subtitle: string;
  description: string;
  language: string;
  path: string;
  level?: string;
}
const { title, subtitle, description, language, path, level } = Astro.props;

const colorMap1: Record<string, string> = {
  eng: "var(--pink500)",
  fra: "var(--blue500)",
  deu: "var(--amber500)",
  ita: "var(--emerald500)",
  swe: "var(--cyan500)",
  spa: "var(--rose500)",
  nld: "var(--orange500)",
  hun: "var(--lime500)",
};
const colorMap2: Record<string, string> = {
  eng: "var(--pink400)",
  fra: "var(--blue400)",
  deu: "var(--amber400)",
  ita: "var(--emerald400)",
  swe: "var(--cyan400)",
  spa: "var(--rose400)",
  nld: "var(--orange400)",
  hun: "var(--lime400)",
};
const colorMap3: Record<string, string> = {
  eng: "var(--pink300)",
  fra: "var(--blue300)",
  deu: "var(--amber300)",
  ita: "var(--emerald300)",
  swe: "var(--cyan300)",
  spa: "var(--rose300)",
  nld: "var(--orange300)",
  hun: "var(--lime300)",
};
const colorMap4: Record<string, string> = {
  eng: "var(--pink200)",
  fra: "var(--blue200)",
  deu: "var(--amber200)",
  ita: "var(--emerald200)",
  swe: "var(--cyan200)",
  spa: "var(--rose200)",
  nld: "var(--orange200)",
  hun: "var(--lime200)",
};
const colorMap5: Record<string, string> = {
  eng: "var(--pink100)",
  fra: "var(--blue100)",
  deu: "var(--amber100)",
  ita: "var(--emerald100)",
  swe: "var(--cyan100)",
  spa: "var(--rose100)",
  nld: "var(--orange100)",
  hun: "var(--lime100)",
};
const color500 = colorMap1[language] || "var(--zinc500)";
const color400 = colorMap2[language] || "var(--zinc400)";
const color300 = colorMap3[language] || "var(--zinc300)";
const color200 = colorMap4[language] || "var(--zinc200)";
const color100 = colorMap5[language] || "var(--zinc100)";

const greetingMap: Record<string, string> = {
  eng: "Welcome",
  fra: "Bienvenue",
  deu: "Willkommen",
  ita: "Benvenuti",
  swe: "Välkommen",
  spa: "Bienvenido",
  nld: "Welkom",
  ces: "Vítejte",
  hun: "Üdvözöljük",
};
const greeting = greetingMap[language] || "Welcome";
---

<style define:vars={{ color500, color400, color300, color200, color100 }}>
  .btn > h3 {
    color: var(--color500);
  }

  .btn:hover {
    background: linear-gradient(
      -45deg,
      var(--color300),
      var(--color100),
      var(--color200)
    );
    background-size: 300% 300%;
    animation: gradient 4s ease infinite;
  }

  @keyframes gradient {
    0% {
      background-position: 0% 50%;
    }

    50% {
      background-position: 100% 50%;
    }

    100% {
      background-position: 0% 50%;
    }
  }

  .btn:hover > h1,
  .btn:hover > h2,
  .btn:hover > p {
    color: var(--color500);
  }

  .btn:hover > h3 {
    opacity: 1;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
</style>

<a href={path}>
  <div class="btn">
    <h1>{title}</h1>
    <h2>{subtitle}</h2>
    <p>{description}</p>
    <h3>{greeting}</h3>
  </div>
</a>

<style>
  .btn {
    position: relative;
    background-color: var(--neutral200);
    padding: 1rem;
    min-height: 200px;
    width: 100%;
    height: 100%;
    transition: all 0.4s;
  }

  .btn > h1 {
    position: relative;
    font-family: "Roboto Condensed", sans-serif;
    font-size: 40px;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 0rem;
    transition: all 0.4s;
  }

  .btn > h2 {
    position: relative;
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--zinc500);
    transition: all 0.4s;
  }

  .btn > p {
    display: inline-block;
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    text-align: right;
    margin-top: 2rem;
    margin-bottom: 0rem;
    font-size: 15px;
    font-weight: 500;
    color: var(--zinc500);
  }

  .btn > h3 {
    position: absolute;
    text-align: center;
    margin: 0;
    top: 60%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: "Roboto Condensed", sans-serif;
    text-transform: uppercase;
    width: 50%;
    font-size: 24px;
    font-weight: 600;
    color: var(--zinc800);
    opacity: 0;
    transition: all 0.4s;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .btn {
      min-height: 160px;
    }

    .btn > h1 {
      font-size: 22px;
    }

    .btn > h2 {
      font-size: 15px;
      font-weight: 500;
    }

    .btn > h3 {
      font-size: 15px;
    }

    .btn > p {
      font-size: 13px;
      font-weight: 500;
    }
  }
</style>
