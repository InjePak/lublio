---
// Logo
import LogoSVG from "../../public/lublio-logo-light.svg?raw";
---

<header id="main-header" class="header">
  <div class="logo">
    <a href="/">
      <Fragment set:html={LogoSVG} />
    </a>
  </div>

  <!-- <span id="menu-trigger" class="material-symbols-outlined">menu</span> -->
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    justify-self: right;
    width: auto;
    max-width: 768px;
    margin: 0 auto;
    height: 40px;
    z-index: 99;
    transition: all 0.4s;
    opacity: 0;
    background-color: transparent;
    transform: translateY(-50px);
  }

  .overlay {
    display: none;
  }

  .logo {
    position: relative;
    width: 40px; /* 원하는 크기 조절 */
    height: auto;
    margin-left: auto;
    padding: 0.5rem;
    transition: 0.4s all;
  }

  .logo > a {
    width: 100%;
    height: 100%;
  }

  .logo :global(svg) {
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
  }

  .sticky {
    background-color: rgba(228, 228, 231, 0.8);
    backdrop-filter: blur(2px);
    margin-top: 1.5rem;
    padding: 0;
    opacity: 1;
    transform: translateY(0px);
  }

  /* Mobile */
  @media (max-width: 992px) {
  }
</style>

<script>
  // 클라이언트 측 로직 (스크롤 및 메뉴 토글)
  const header = document.getElementById("main-header");
  const menuTrigger = document.getElementById("menu-trigger");
  const menuClose = document.getElementById("menu-close");
  const overlay = document.getElementById("overlay-menu");

  // 1. Sticky Header 로직
  window.addEventListener(
    "scroll",
    () => {
      if (window.scrollY > 0) {
        header?.classList.add("sticky");
      } else {
        header?.classList.remove("sticky");
      }
    },
    { passive: true },
  );

  // 2. 오버레이 메뉴 제어
  menuTrigger?.addEventListener("click", () => {
    overlay?.classList.add("overlayActive");
  });

  menuClose?.addEventListener("click", () => {
    overlay?.classList.remove("overlayActive");
  });
</script>
