<script>
  // Overlay Menu 로직
  const overlay = document.getElementById("overlay-menu");
  const openBtn = document.getElementById("menu-open-btn");
  const closeBtn = document.getElementById("menu-close-btn");

  openBtn?.addEventListener("click", () => {
    overlay?.classList.add("overlayActive"); // styles.overlayActive 역할
  });

  closeBtn?.addEventListener("click", () => {
    overlay?.classList.remove("overlayActive");
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    justify-self: left;
    width: 250px;
    height: 100%;
    z-index: 99;
    transition: all 0.4s;
    padding: 1.5rem 0;
    background-color: var(--neutral100);
  }

  .logo {
    position: relative;
    width: 60px;
    height: 60px;
    margin: 0 auto;
    padding: 0.7rem;
    transition: 0.4s all;
  }

  .logo > a {
    width: 100%;
    height: 100%;
  }

  .logo :global(svg) {
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
  }

  .logo:hover {
    cursor: pointer;
    background-color: var(--neutral300);
  }

  .menu {
    position: absolute;
    display: block;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    height: auto;
    padding: 1rem 0;
    text-align: center;
  }

  .menu > li {
    width: auto;
    margin-bottom: 1rem;
  }

  .menu > li:last-child {
    margin-bottom: 0rem;
  }

  .menu-link {
    display: inline-block;
    font-family: "Inter", sans-serif;
    font-size: 28px;
    font-weight: 600;
    color: var(--neutral800);
    padding: 0.5rem 1rem;
    transition: 0.4s all;
  }

  .menu-link:hover {
    background-color: var(--neutral300);
  }
</style>

<script></script>
