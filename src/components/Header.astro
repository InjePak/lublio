---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";
import { Icon } from "astro-icon/components";

// Logo
import LogoSVG from "../../public/lublio-logo-light.svg?raw";
---

<header id="main-header" class="header">
  <div class="logo">
    <a href="/">
      <Fragment set:html={LogoSVG} />
    </a>
  </div>
  <ul class="menu">
    <li>
      <a href="/english" class="menu-link">영어</a>
    </li>
    <li>
      <a href="/german" class="menu-link">독일어</a>
    </li>
    <li>
      <a href="/french" class="menu-link">프랑스어</a>
    </li>
    <li>
      <a href="/russian" class="menu-link">러시아어</a>
    </li>
    <!-- <li>
      <a href="/hebrew" class="menu-link">히브리어</a>
    </li>
    <li>
      <a href="/kazakh" class="menu-link">카자흐어</a>
    </li> -->
  </ul>
</header>

