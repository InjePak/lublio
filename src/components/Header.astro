---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";
import { Icon } from "astro-icon/components";

// Logo
import LogoSVG from "../../public/lublio-logo-light.svg?raw";
---

<header id="main-header" class="header">
  <div class="logo">
    <a id="menu-open-btn">
      <Fragment set:html={LogoSVG} />
    </a>
  </div>
</header>

<div id="overlay-menu" class="overlay">
  <!-- Panels -->
  <div class="overlay-panel panel-1"></div>
  <div class="overlay-panel panel-2"></div>
  <div class="overlay-panel panel-3"></div>
  <div class="overlay-panel panel-4"></div>
  <div class="overlay-panel panel-5"></div>
  <div class="overlay-panel panel-6"></div>

  <div class="overlayContent">
    <a id="menu-close-btn" class="close">&times;</a>
    <ul class="menuList">
      <li>
        <a href="/" class="menuLink">Home</a>
      </li>
      <li>
        <a href="/german" class="menuLink">German</a>
      </li>
      <li>
        <a href="/french" class="menuLink">French</a>
      </li>
      <li>
        <a href="/spanish" class="menuLink">Spanish</a>
      </li>
      <li>
        <a href="/italian" class="menuLink">Italian</a>
      </li>
      <li>
        <a href="/russian" class="menuLink">Russian</a>
      </li>
      <li>
        <a href="/turkish" class="menuLink">Turkish</a>
      </li>
      <li>
        <a href="/about" class="menuLink">About</a>
      </li>
    </ul>
  </div>
</div>

<script>
  // Overlay Menu 로직
  const overlay = document.getElementById("overlay-menu");
  const openBtn = document.getElementById("menu-open-btn");
  const closeBtn = document.getElementById("menu-close-btn");

  openBtn?.addEventListener("click", () => {
    overlay?.classList.add("overlayActive"); // styles.overlayActive 역할
  });

  closeBtn?.addEventListener("click", () => {
    overlay?.classList.remove("overlayActive");
  });
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    justify-self: right;
    width: auto;
    max-width: 768px;
    margin: 0 auto;
    height: 40px;
    z-index: 99;
    transition: all 0.4s;
    opacity: 0;
    background-color: transparent;
    transform: translateY(-50px);
  }

  .logo {
    position: relative;
    width: 40px; /* 원하는 크기 조절 */
    height: auto;
    margin-left: auto;
    padding: 0.5rem;
    transition: 0.4s all;
  }

  .logo > a {
    width: 100%;
    height: 100%;
  }

  .logo :global(svg) {
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
  }

  .sticky {
    background-color: rgba(228, 228, 231, 0.8);
    backdrop-filter: blur(2px);
    margin-top: 1.5rem;
    padding: 0;
    opacity: 1;
    transform: translateY(0px);
  }

  .sticky:hover {
    cursor: pointer;
    background-color: rgba(212, 212, 216, 0.8);
  }

  .overlay {
    position: fixed;
    display: flex;
    flex-direction: column;
    justify-content: end;
    opacity: 1;
    height: 100vh;
    width: 0%;
    z-index: 999;
    right: 0px;
    top: 50%;
    margin: 0;
    transform: translateY(-50%);
    background-color: transparent;
    text-transform: uppercase;
    transition: width 0s linear 0.9s;
  }

  .overlayActive {
    opacity: 1;
    width: 100%;
    transition: width 0s;
  }

  .overlay-panel {
    position: absolute;
    top: 0;
    right: 0;
    width: 0%;
    height: 100%;
    transition: width 0.5s cubic-bezier(0.77, 0, 0.175, 1);
  }

  /* Gradation Style */
  .panel-1 {
    background-color: var(--pink400);
    transition-delay: 0s;
  }
  .panel-2 {
    background-color: var(--orange400);
    transition-delay: 0.1s;
  }
  .panel-3 {
    background-color: var(--amber400);
    transition-delay: 0.2s;
  }
  .panel-4 {
    background-color: var(--emerald400);
    transition-delay: 0.3s;
  }
  .panel-5 {
    background-color: var(--sky400);
    transition-delay: 0.4s;
  }
  .panel-6 {
    background-color: var(--zinc100);
    transition-delay: 0.5s;
  }

  .overlayActive .overlay-panel {
    width: 100%;
  }

  .overlay:not(.overlayActive) .panel-1 {
    transition-delay: 0.5s;
  }
  .overlay:not(.overlayActive) .panel-2 {
    transition-delay: 0.4s;
  }
  .overlay:not(.overlayActive) .panel-3 {
    transition-delay: 0.3s;
  }
  .overlay:not(.overlayActive) .panel-4 {
    transition-delay: 0.2s;
  }
  .overlay:not(.overlayActive) .panel-5 {
    transition-delay: 0.1s;
  }
  .overlay:not(.overlayActive) .panel-6 {
    transition-delay: 0s;
  }

  .overlayActive .overlayContent {
    opacity: 1;
    transition: opacity 0.7s ease 0.7s; /* 패널이 다 덮인 후 텍스트 등장 */
  }

  .close {
    display: none;
    opacity: 0;
    width: auto;
    height: auto;
    text-align: center;
    z-index: 999;
    transition: all 0.7s ease 0.7s;
  }

  .overlayActive .close {
    display: block;
    position: absolute;
    opacity: 1;
    background-color: transparent;
    top: -5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 40px;
    font-family: "Inter", sans-serif;
    font-weight: 400;
    text-decoration: none;
    color: var(--zinc800);
    cursor: pointer;
    transition: all 0.7s ease 0.7s;
  }

  .overlayActive .close:hover {
    cursor: pointer;
    color: var(--zinc400);
  }

  .overlayContent {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    height: auto;
    width: 100%;
    flex-direction: column;
    align-items: center;
    margin-left: auto;
    margin-right: auto;
    text-align: center;
    opacity: 0;
  }

  .menuList {
    opacity: 0;
    list-style: none;
    transform: translateX(200px);
  }

  .overlayActive .menuList {
    background-color: var(--zinc200);
    border-top-right-radius: 50px;
    border-bottom-right-radius: 50px;
    padding: 3rem 1.5rem;
    opacity: 1;
    width: 100%;
    max-width: 200px;
    height: 100%;
    margin: 0;
    transform: translateX(0px);
  }

  .menuList li {
    display: block;
    text-align: left;
    width: auto;
    margin-bottom: 1rem;
    background-color: transparent;
    transition: all 0.4s ease-in-out;
  }

  .menuList li:last-child {
    margin-bottom: 0;
  }

  .menuLink {
    display: inline-block;
    width: 100%;
    height: 100%;
    position: relative;
    margin: 0px;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    font-family: "Roboto Condensed", sans-serif;
    font-size: 24px;
    font-weight: 600;
    transition: all 0.4s;
  }

  .menuLink:hover {
    cursor: pointer;
  }

  .menuLink > svg {
    width: 30px;
    margin-right: 0.5rem;
    color: var(--zinc800);
    transform: translateY(6px);
    transition: all 0.4s;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .overlayActive .menuList {
      padding: 3rem 1.5rem;
      max-width: 220px;
    }

    .menuLink {
      font-size: 24px;
    }
  }
</style>

<script>
  // 클라이언트 측 로직 (스크롤 및 메뉴 토글)
  const header = document.getElementById("main-header");
  const menuTrigger = document.getElementById("menu-trigger");
  const menuClose = document.getElementById("menu-close");
  const overlay = document.getElementById("overlay-menu");

  // 1. Sticky Header 로직
  window.addEventListener(
    "scroll",
    () => {
      if (window.scrollY > 0) {
        header?.classList.add("sticky");
      } else {
        header?.classList.remove("sticky");
      }
    },
    { passive: true },
  );

  // 2. 오버레이 메뉴 제어
  menuTrigger?.addEventListener("click", () => {
    overlay?.classList.add("overlayActive");
  });

  menuClose?.addEventListener("click", () => {
    overlay?.classList.remove("overlayActive");
  });
</script>
