---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";

const { title, subtitle, description, language, path } = Astro.props;
const colorMap: Record<string, string> = {
  eng: "var(--pink400)",
  fra: "var(--sky400)",
  deu: "var(--amber400)",
  rus: "var(--indigo400)",
  kaz: "var(--cyan400)",
};
const borderColor = colorMap[language] || "var(--zinc400)";
---

<style define:vars={{ borderColor }}>
  .btn:hover {
    border: 2px solid var(--borderColor);
  }
</style>

<a href={path}>
  <div class="btn">
    <h1>{title}</h1>
    <h2>{subtitle}</h2>
    <p>{description}</p>
  </div>
</a>

<style>
  .btn {
    position: relative;
    border: 2px dashed var(--zinc800);
    border-radius: 15px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    min-height: 250px;
    transition: all 0.4s;
  }

  .btn > h1 {
    position: relative;
    font-size: 32px;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .btn > h2 {
    position: relative;
    font-size: 20px;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .btn > p {
    position: absolute;
    left: 1.5rem;
    bottom: 0;
  }

  .btn:hover {
    border-radius: 25px;
  }
</style>
