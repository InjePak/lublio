---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";
import { Icon } from "astro-icon/components";

const { title, subtitle, description, language, path, level } = Astro.props;

const colorMap1: Record<string, string> = {
  eng: "var(--pink500)",
  fra: "var(--sky500)",
  deu: "var(--amber500)",
  ita: "var(--emerald500)",
  esp: "var(--orange500)",
  rus: "var(--indigo500)",
  tur: "var(--rose500)",
  ces: "var(--blue500)",
  hun: "var(--lime500)",
};
const colorMap2: Record<string, string> = {
  eng: "var(--pink400)",
  fra: "var(--sky400)",
  deu: "var(--amber400)",
  ita: "var(--emerald400)",
  esp: "var(--orange400)",
  rus: "var(--indigo400)",
  tur: "var(--rose400)",
  ces: "var(--blue400)",
  hun: "var(--lime400)",
};
const colorMap3: Record<string, string> = {
  eng: "var(--pink300)",
  fra: "var(--sky300)",
  deu: "var(--amber300)",
  ita: "var(--emerald300)",
  esp: "var(--orange300)",
  rus: "var(--indigo300)",
  tur: "var(--rose300)",
  ces: "var(--blue300)",
  hun: "var(--lime300)",
};
const colorMap4: Record<string, string> = {
  eng: "var(--pink200)",
  fra: "var(--sky200)",
  deu: "var(--amber200)",
  ita: "var(--emerald200)",
  esp: "var(--orange200)",
  rus: "var(--indigo200)",
  tur: "var(--rose200)",
  ces: "var(--blue200)",
  hun: "var(--lime200)",
};
const colorMap5: Record<string, string> = {
  eng: "var(--pink100)",
  fra: "var(--sky100)",
  deu: "var(--amber100)",
  ita: "var(--emerald100)",
  esp: "var(--orange100)",
  rus: "var(--indigo100)",
  tur: "var(--rose100)",
  ces: "var(--blue100)",
  hun: "var(--lime100)",
};
const color500 = colorMap1[language] || "var(--zinc500)";
const color400 = colorMap2[language] || "var(--zinc400)";
const color300 = colorMap3[language] || "var(--zinc300)";
const color200 = colorMap4[language] || "var(--zinc200)";
const color100 = colorMap5[language] || "var(--zinc100)";

const levelMap: Record<string, string> = {
  a0: "mdi:chess-pawn",
  a1: "mdi:chess-knight",
  a2: "mdi:chess-bishop",
  b1: "mdi:chess-rook",
  b2: "mdi:chess-queen",
  grammar: "mdi:cube-outline",
  phrase: "mdi:tooltip-text-outline",
  pattern: "mdi:puzzle-outline",
};
const levelIcon = levelMap[level] || "mdi:chess-pawn";
---

<style define:vars={{ color500, color400, color300, color200, color100 }}>
  .btn:hover {
    background: var(--color100);
  }

  .btn:hover > h1,
  .btn:hover > h2,
  .btn:hover > p {
    color: var(--color500);
  }

  .btn:hover > svg {
    opacity: 1;
    color: var(--color500);
  }
</style>

<a href={path}>
  <div class="btn">
    <h1>{title}</h1>
    <h2>{subtitle}</h2>
    <p>{description}</p>
    {level && <Icon name={levelIcon} />}
  </div>
</a>

<style>
  .btn {
    position: relative;
    background-color: var(--neutral200);
    padding: 1rem;
    margin-bottom: 1.5rem;
    min-height: 150px;
    transition: all 0.4s;
  }

  .btn > h1 {
    position: relative;
    font-family: "Roboto Condensed", sans-serif;
    text-transform: uppercase;
    font-size: 32px;
    font-weight: 600;
    margin-bottom: 0rem;
    transition: 0.4s all;
  }

  .btn > h2 {
    position: relative;
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 0.5rem;
    transition: 0.4s all;
  }

  .btn > p {
    display: inline-block;
    text-align: right;
    margin-top: 2rem;
    margin-bottom: 0rem;
    font-size: 14px;
    transition: 0.4s all;
  }

  .btn > svg {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 30px;
    height: 30px;
    opacity: 0;
    color: var(--zinc800);
    transition: all 0.6s;
  }

  /* Mobile */
  @media (max-width: 480px) {
    /* .btn > h1 {
      font-size: 22px;
      width: 90%;
    }

    .btn > h2 {
      font-size: 15px;
    }

    .btn > p {
      font-size: 12px;
    } */
  }
</style>
