---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";
import { Icon } from "astro-icon/components";

const { title, subtitle, description, language, path, level, isDev } =
  Astro.props;

const colorMap1: Record<string, string> = {
  eng: "var(--pink500)",
  fra: "var(--blue500)",
  deu: "var(--amber500)",
  ita: "var(--emerald500)",
  swe: "var(--cyan500)",
  spa: "var(--rose500)",
  nld: "var(--orange500)",
  hun: "var(--lime500)",
};
const colorMap2: Record<string, string> = {
  eng: "var(--pink400)",
  fra: "var(--blue400)",
  deu: "var(--amber400)",
  ita: "var(--emerald400)",
  swe: "var(--cyan400)",
  spa: "var(--rose400)",
  nld: "var(--orange400)",
  hun: "var(--lime400)",
};
const colorMap3: Record<string, string> = {
  eng: "var(--pink300)",
  fra: "var(--blue300)",
  deu: "var(--amber300)",
  ita: "var(--emerald300)",
  swe: "var(--cyan300)",
  spa: "var(--rose300)",
  nld: "var(--orange300)",
  hun: "var(--lime300)",
};
const colorMap4: Record<string, string> = {
  eng: "var(--pink200)",
  fra: "var(--blue200)",
  deu: "var(--amber200)",
  ita: "var(--emerald200)",
  swe: "var(--cyan200)",
  spa: "var(--rose200)",
  nld: "var(--orange200)",
  hun: "var(--lime200)",
};
const colorMap5: Record<string, string> = {
  eng: "var(--pink100)",
  fra: "var(--blue100)",
  deu: "var(--amber100)",
  ita: "var(--emerald100)",
  swe: "var(--cyan100)",
  spa: "var(--rose100)",
  nld: "var(--orange100)",
  hun: "var(--lime100)",
};
const color500 = colorMap1[language] || "var(--zinc500)";
const color400 = colorMap2[language] || "var(--zinc400)";
const color300 = colorMap3[language] || "var(--zinc300)";
const color200 = colorMap4[language] || "var(--zinc200)";
const color100 = colorMap5[language] || "var(--zinc100)";

const levelMap: Record<string, string> = {
  a0: "mdi:chess-pawn",
  a1: "mdi:chess-knight",
  a2: "mdi:chess-bishop",
  b1: "mdi:chess-rook",
  b2: "mdi:chess-queen",
  grammar: "mdi:cube-outline",
  phrase: "mdi:tooltip-text-outline",
  pattern: "mdi:puzzle-outline",
  culture: "mdi:asterisk",
};
const levelIcon = levelMap[level] || "mdi:chess-pawn";
---

<style define:vars={{ color500, color400, color300, color200, color100 }}>
  .btn:hover {
    background: var(--color100);
  }

  .btn:hover > h1,
  .btn:hover > h2,
  .btn:hover > p {
    color: var(--color500);
  }

  .btn:hover > svg,
  .btn:hover > span {
    opacity: 1;
    color: var(--color500);
  }
</style>

<a href={path}>
  <div class="btn">
    <h1>{title}</h1>
    <h2>{subtitle}</h2>
    <p>{description}</p>
    {level && <Icon name={levelIcon} />}
    {isDev && <span>Coming Soon</span>}
  </div>
</a>

<style>
  .btn {
    position: relative;
    background-color: var(--neutral200);
    padding: 1rem;
    min-height: 350px;
    width: 100%;
    height: 100%;
    transition: all 0.4s;
  }

  .btn > h1 {
    position: relative;
    font-family: "Roboto Condensed", sans-serif;
    text-transform: uppercase;
    font-size: 32px;
    font-weight: 600;
    margin-bottom: 0rem;
    transition: 0.4s all;
  }

  .btn > h2 {
    position: relative;
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--zinc500);
    transition: 0.4s all;
  }

  .btn > p {
    position: absolute;
    display: block;
    margin: 0;
    text-align: right;
    bottom: 1rem;
    right: 1rem;
    width: calc(100% - 2rem);
    font-size: 14px;
    transition: 0.4s all;
    color: var(--zinc500);
  }

  .btn > span {
    position: absolute;
    display: block;
    bottom: 1rem;
    left: 1rem;
    font-weight: 600;
    font-size: 18px;
    font-family: "Roboto Condensed", sans-serif;
    text-transform: uppercase;
    color: var(--zinc800);
    opacity: 0;
    transition: 0.4s all;
  }

  .btn > svg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 30px;
    height: 30px;
    margin: 0;
    opacity: 0;
    color: var(--zinc800);
    transition: all 0.4s;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .btn {
      min-height: 300px;
    }

    .btn > h1 {
      font-size: 17px;
    }

    .btn > h2 {
      font-size: 14px;
    }

    .btn > p {
      font-size: 12px;
    }

    .btn > span {
      opacity: 0;
      font-size: 14px;
      width: 100%;
      height: 18px;
      text-align: center;
      top: 60%;
      left: 50%;
      transform: translate(-50%, -50%);
    }

    .btn > svg {
      width: 24px;
      height: 24px;
    }
  }
</style>
