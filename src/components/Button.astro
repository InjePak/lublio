---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";
import { Icon } from "astro-icon/components";

const { title, subtitle, description, language, path, level } = Astro.props;

const colorMap1: Record<string, string> = {
  eng: "var(--pink400)",
  fra: "var(--sky400)",
  deu: "var(--amber400)",
  ita: "var(--emerald400)",
  esp: "var(--orange400)",
  rus: "var(--indigo400)",
  tur: "var(--rose400)",
  ces: "var(--blue400)",
  hun: "var(--lime400)",
};
const colorMap2: Record<string, string> = {
  eng: "var(--pink200)",
  fra: "var(--sky200)",
  deu: "var(--amber200)",
  ita: "var(--emerald200)",
  esp: "var(--orange200)",
  rus: "var(--indigo200)",
  tur: "var(--rose200)",
  ces: "var(--blue200)",
  hun: "var(--lime200)",
};
const borderColor = colorMap1[language] || "var(--zinc400)";
const backgroundColor = colorMap2[language] || "var(--zinc300)";

const levelMap: Record<string, string> = {
  a0: "mdi:chess-pawn",
  a1: "mdi:chess-knight",
  a2: "mdi:chess-bishop",
  b1: "mdi:chess-rook",
  b2: "mdi:chess-queen",
  phrase: "mdi:tooltip-text-outline",
  pattern: "mdi:puzzle-outline",
};
const levelIcon = levelMap[level] || "mdi:chess-pawn";
---

<style define:vars={{ borderColor, backgroundColor }}>
  .btn:hover {
    border: 2px solid var(--borderColor);
    background: linear-gradient(
      -45deg,
      var(--backgroundColor),
      var(--zinc200),
      var(--zinc200)
    );
    background-size: 300% 300%;
    animation: gradient 4s ease infinite;
  }

  @keyframes gradient {
    0% {
      background-position: 0% 50%;
    }

    50% {
      background-position: 100% 50%;
    }

    100% {
      background-position: 0% 50%;
    }
  }

  .btn:hover > svg {
    opacity: 1;
    color: var(--borderColor);
  }
</style>

<a href={path}>
  <div class="btn">
    <h1>{title}</h1>
    <h2>{subtitle}</h2>
    <p>{description}</p>
    {level && <Icon name={levelIcon} />}
  </div>
</a>

<style>
  .btn,
  .btn2 {
    position: relative;
    border: 2px dashed var(--zinc800);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    min-height: 150px;
    transition: all 0.4s;
  }

  .btn > h1,
  .btn2 > h1 {
    position: relative;
    font-size: 26px;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .btn > h2,
  .btn2 > h2 {
    position: relative;
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .btn > p,
  .btn2 > p {
    display: inline-block;
    text-align: right;
    margin-top: 2rem;
    margin-bottom: 0rem;
    font-size: 14px;
  }

  .btn > svg {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 30px;
    height: 30px;
    opacity: 0;
    color: var(--zinc800);
    transition: all 0.6s;
  }

  .btn:hover,
  .btn2:hover {
    border-radius: 15px;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .btn > h1,
    .btn2 > h1 {
      font-size: 22px;
      width: 90%;
    }

    .btn > h2,
    .btn2 > h2 {
      font-size: 15px;
    }

    .btn > p,
    .btn2 > p {
      font-size: 12px;
    }
  }
</style>
