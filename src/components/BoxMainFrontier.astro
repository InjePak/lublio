  nld: "rgba(255, 237, 213, 1)",
  fra: "rgba(224, 242, 254, 1)",
  deu: "rgba(254, 243, 199, 1)",
  ita: "rgba(209, 250, 229, 1)",
  spa: "rgba(255, 228, 230, 1)",
  rus: "rgba(224, 231, 255, 1)",
  heb: "rgba(219, 234, 254, 1)",
  kaz: "rgba(204, 251, 241, 1)",
