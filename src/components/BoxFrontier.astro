---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";

const { title, subtitle, description, language } = Astro.props;

const colorMap800: Record<string, string> = {
  heb: "rgba(30, 64, 175, 1)",
  kaz: "rgba(21, 94, 117, 1)",
  fra: "rgba(7, 89, 133, 1)",
  rus: "rgba(55, 48, 163, 1)",
};
const colorMap700: Record<string, string> = {
  heb: "rgba(29, 78, 216, 1)",
  kaz: "rgba(14, 116, 144, 1)",
  fra: "rgba(3, 105, 161, 1)",
  rus: "rgba(67, 56, 202, 1)",
};
const colorMap600: Record<string, string> = {
  heb: "rgba(37, 99, 235, 1)",
  kaz: "rgba(8, 145, 178, 1)",
  fra: "rgba(2, 132, 199, 1)",
  rus: "rgba(79, 70, 229, 1)",
};
const colorMap500: Record<string, string> = {
  heb: "rgba(59, 130, 246, 1)",
  kaz: "rgba(6, 182, 212, 1)",
  fra: "rgba(14, 165, 233, 1)",
  rus: "rgba(99, 102, 241, 1)",
};
const colorMap400: Record<string, string> = {
  heb: "rgba(96, 165, 250, 1)",
  kaz: "rgba(34, 211, 238, 1)",
  fra: "rgba(56, 189, 248, 1)",
  rus: "rgba(129, 140, 248, 1)",
};
const colorMap300: Record<string, string> = {
  heb: "rgba(147, 197, 253, 1)",
  kaz: "rgba(103, 232, 249, 1)",
  fra: "rgba(125, 211, 252, 1)",
  rus: "rgba(165, 180, 252, 1)",
};
const colorMap200: Record<string, string> = {
  heb: "rgba(191, 219, 254, 1)",
  kaz: "rgba(165, 243, 252, 1)",
  fra: "rgba(186, 230, 253, 1)",
  rus: "rgba(199, 210, 254, 1)",
};
const colorMap100: Record<string, string> = {
  heb: "rgba(219, 234, 254, 1)",
  kaz: "rgba(207, 250, 254, 1)",
  fra: "rgba(224, 242, 254, 1)",
  rus: "rgba(224, 231, 255, 1)",
};
const color800 = colorMap800[language] || "var(--zinc800)";
const color700 = colorMap700[language] || "var(--zinc700)";
const color600 = colorMap600[language] || "var(--zinc600)";
const color500 = colorMap500[language] || "var(--zinc500)";
const color400 = colorMap400[language] || "var(--zinc400)";
const color300 = colorMap300[language] || "var(--zinc300)";
const color200 = colorMap200[language] || "var(--zinc200)";
const color100 = colorMap100[language] || "var(--zinc100)";
---

<style
  define:vars={{
    color800,
    color700,
    color600,
    color500,
    color400,
    color300,
    color200,
    color100,
  }}
>
  .box > h2,
  .box > h3,
  .box > p {
    color: var(--neutral800);
  }

  .box .loader::before,
  .box .loader::after {
    background-color: var(--color400);
  }
</style>

<div class="box riseUp_1">
  <h2 class="fade_2">{title}</h2>
  <h3 class="fade_3">{subtitle}</h3>
  <div class="item">
    <i class="loader"></i>
  </div>
  <p class="fade_4">{description}</p>
</div>

<style>
  .box {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    height: 400px;
    margin-bottom: 2rem;
    outline: none;
    z-index: 0;
    text-decoration: none;
    padding: 1.5rem;
    border: 2px solid rgba(38, 38, 38, 0.8);
    border-radius: 20px;
    background-color: transparent;
    transition: all 1s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .box > h2 {
    position: relative;
    font-family: "Inter", sans-serif;
    text-transform: uppercase;
    display: inline;
    font-size: 50px;
    font-weight: 600;
    line-height: 1;
    word-break: keep-all;
    word-wrap: break-word;
    transition: all 0.4s;
  }

  .box > h3 {
    position: relative;
    font-family: "Noto Korean", sans-serif;
    display: block;
    font-size: 24px;
    font-weight: 600;
    letter-spacing: 0px;
    line-height: 1;
    margin-top: 10px;
    transition: all 0.4s;
  }

  .box > p {
    position: absolute;
    font-family: "Noto Korean", sans-serif;
    width: calc(100% - 3rem);
    left: 1.5rem;
    bottom: 1.5rem;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0px;
    line-height: 1.4;
    transition: all 0.4s;
  }

  .box > p:last-child {
    margin-bottom: 0px;
  }

  .box > h2,
  .box > h3,
  .box > h4,
  .box > span,
  .box > p {
    color: var(--neutral800);
  }

  /* Moving Item */

  .box .item {
    position: absolute;
    display: grid;
    top: 2.5rem;
    right: 2.5rem;
    place-items: center;
    transition: all 0.4s ease;
  }

  .box .loader {
    display: block;
    position: relative;
    width: 50%;
    display: grid;
    place-items: center;
    cursor: default;
  }

  .box .loader::before,
  .box .loader::after {
    content: "";
    box-sizing: border-box;
    position: absolute;
    width: 10px;
    height: 10px;
  }

  .box .loader::before,
  .box .loader::after {
    background-color: var(--zinc400);
  }

  .box .loader::before {
    top: calc(50% - 10px);
    left: calc(50% - 10px);
    animation: loader1 2.4s cubic-bezier(0, 0, 0.24, 1.21) infinite;
  }

  .box .loader::after {
    top: 50%;
    left: 50%;
    animation: loader2 2.4s cubic-bezier(0, 0, 0.24, 1.21) infinite;
  }

  @keyframes loader1 {
    0%,
    100% {
      transform: none;
    }

    25% {
      transform: translateX(100%);
    }

    50% {
      transform: translateX(100%) translateY(100%);
    }

    75% {
      transform: translateY(100%);
    }
  }

  @keyframes loader2 {
    0%,
    100% {
      transform: none;
    }

    25% {
      transform: translateX(-100%);
    }

    50% {
      transform: translateX(-100%) translateY(-100%);
    }

    75% {
      transform: translateY(-100%);
    }
  }

  /* Mobile */
  @media (max-width: 480px) {
    .box > h2 {
      font-size: 38px;
    }

    .box > h2::after {
      height: 10px;
      bottom: 6px;
      left: 0;
      opacity: 0.8;
      z-index: -1;
      transform-origin: bottom left;
      animation: underline 2.4s cubic-bezier(0, 0, 0.24, 1.21);
    }

    .box > h3 {
      font-size: 18px;
    }

    .box > p {
      font-size: 13px;
    }
  }
</style>
