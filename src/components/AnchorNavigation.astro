---
const { items } = Astro.props;
---

<>
  <div class="anchor-nav">
    <ul>
      {
        items.map((item: any) => (
          <li>
            <a href={`#${item.id}`} data-anchor-link>
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</>

<style>
  .anchor-nav {
    margin-bottom: 1.5rem;
  }

  ul {
    display: flex;
    justify-content: center;
    flex-direction: row;
    font-size: 1rem;
    font-weight: 500;
    gap: 1rem;
    width: 100%;
    height: 100%;
  }

  li {
    width: 20%;
    text-align: center;
  }

  a {
    display: inline-block;
    border: 2px solid var(--zinc800);
    border-radius: 50px;
    width: 100%;
    padding: 0.5rem;
  }

  a:hover {
    color: var(--zinc800);
    background: var(--zinc300);
  }
</style>

<script>
  // ScrollSpy
  const links = document.querySelectorAll("[data-anchor-link]");
  const sections = Array.from(links).map((link) =>
    document.getElementById(link.getAttribute("href")!.substring(1)),
  );

  window.addEventListener("scroll", () => {
    let current = "";

    sections.forEach((section) => {
      if (!section) return;
      const sectionTop = section.offsetTop;
      if (window.scrollY >= sectionTop - 100) {
        current = section.getAttribute("id")!;
      }
    });

    links.forEach((link) => {
      link.classList.remove("active");
      if (link.getAttribute("href") === `#${current}`) {
        link.classList.add("active");
      }
    });
  });
</script>
