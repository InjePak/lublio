---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";

interface Props {
  title: string;
  subtitle: string;
  description: string;
  language: string;
  path: string;
  level?: string;
}
const { title, subtitle, description, language, path, level } = Astro.props;

const colorMap800: Record<string, string> = {
  fra: "rgba(7, 89, 133, 1)",
  rus: "rgba(55, 48, 163, 1)",
  heb: "rgba(30, 64, 175, 1)",
  kaz: "rgba(17, 94, 89, 1)",
};
const colorMap700: Record<string, string> = {
  fra: "rgba(3, 105, 161, 1)",
  rus: "rgba(67, 56, 202, 1)",
  heb: "rgba(29, 78, 216, 1)",
  kaz: "rgba(15, 118, 110, 1)",
};
const colorMap600: Record<string, string> = {
  fra: "rgba(2, 132, 199, 1)",
  rus: "rgba(79, 70, 229, 1)",
  heb: "rgba(37, 99, 235, 1)",
  kaz: "rgba(13, 148, 136, 1)",
};
const colorMap500: Record<string, string> = {
  fra: "rgba(14, 165, 233, 1)",
  rus: "rgba(99, 102, 241, 1)",
  heb: "rgba(59, 130, 246, 1)",
  kaz: "rgba(20, 184, 166, 1)",
};
const colorMap400: Record<string, string> = {
  fra: "rgba(56, 189, 248, 1)",
  rus: "rgba(129, 140, 248, 1)",
  heb: "rgba(96, 165, 250, 1)",
  kaz: "rgba(45, 212, 191, 1)",
};
const colorMap300: Record<string, string> = {
  fra: "rgba(125, 211, 252, 1)",
  rus: "rgba(165, 180, 252, 1)",
  heb: "rgba(147, 197, 253, 1)",
  kaz: "rgba(94, 234, 212, 1)",
};
const colorMap200: Record<string, string> = {
  fra: "rgba(186, 230, 253, 1)",
  rus: "rgba(199, 210, 254, 1)",
  heb: "rgba(191, 219, 254, 1)",
  kaz: "rgba(153, 246, 228, 1)",
};
const colorMap100: Record<string, string> = {
  fra: "rgba(224, 242, 254, 1)",
  rus: "rgba(224, 231, 255, 1)",
  heb: "rgba(219, 234, 254, 1)",
  kaz: "rgba(204, 251, 241, 1)",
};
const color800 = colorMap800[language] || "var(--zinc800)";
const color700 = colorMap700[language] || "var(--zinc700)";
const color600 = colorMap600[language] || "var(--zinc600)";
const color500 = colorMap500[language] || "var(--zinc500)";
const color400 = colorMap400[language] || "var(--zinc400)";
const color300 = colorMap300[language] || "var(--zinc300)";
const color200 = colorMap200[language] || "var(--zinc200)";
const color100 = colorMap100[language] || "var(--zinc100)";

const greetingMap: Record<string, string> = {
  fra: "Bonjour",
  rus: "Здравствуйте",
  heb: "שלום",
  kaz: "Сәлем",
};
const greeting = greetingMap[language] || "Welcome";
---

<style define:vars={{ color500, color400, color300, color200, color100 }}>
  .btn > h3 {
    color: var(--color400);
  }

  .btn:hover {
    background-color: rgba(255, 255, 255, 0.2);
    border: 1px solid var(--color400);
  }

  .btn:hover > h1,
  .btn:hover > h2,
  .btn:hover > p {
    color: var(--color400);
  }

  .btn:hover > h3 {
    opacity: 1;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
</style>

<a href={path}>
  <div class="btn">
    <h1>{title}</h1>
    <h2>{subtitle}</h2>
    <p>{description}</p>
    <h3>{greeting}</h3>
  </div>
</a>

<style>
  .btn {
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background-color: rgba(255, 255, 255, 0.1);
    padding: 1rem;
    min-height: 240px;
    width: 100%;
    height: 100%;
    margin-bottom: 0.5rem;
    transition: all 0.4s;
  }

  .btn > h1 {
    position: relative;
    font-family: "Roboto Condensed", sans-serif;
    font-size: 40px;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 0rem;
    transition: all 0.4s;
  }

  .btn > h2 {
    position: relative;
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--zinc500);
    transition: all 0.4s;
  }

  .btn > p {
    display: inline-block;
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    text-align: right;
    margin-top: 2rem;
    margin-bottom: 0rem;
    font-size: 15px;
    font-weight: 500;
    color: var(--zinc500);
  }

  .btn > h3 {
    position: absolute;
    text-align: center;
    margin: 0;
    top: 60%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: "Inter", "Noto Hebrew", sans-serif;
    width: 50%;
    font-size: 24px;
    font-weight: 600;
    color: var(--zinc800);
    opacity: 0;
    transition: all 0.4s;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .btn {
      min-height: 300px;
    }

    .btn > h1 {
      font-size: 30px;
    }

    .btn > h2 {
      font-size: 16px;
      font-weight: 500;
    }

    .btn > h3 {
      font-size: 18px;
    }

    .btn > p {
      font-size: 13px;
      font-weight: 500;
    }
  }
</style>
