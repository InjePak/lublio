---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";

interface Props {
  title: string;
  subtitle: string;
  language: string;
  path: string;
  level?: string;
}
const { title, subtitle, language, path } = Astro.props;

const colorMap800: Record<string, string> = {
  heb: "rgba(30, 64, 175, 1)",
  kaz: "rgba(21, 94, 117, 1)",
  fra: "rgba(7, 89, 133, 1)",
  rus: "rgba(55, 48, 163, 1)",
};
const colorMap700: Record<string, string> = {
  heb: "rgba(29, 78, 216, 1)",
  kaz: "rgba(14, 116, 144, 1)",
  fra: "rgba(3, 105, 161, 1)",
  rus: "rgba(67, 56, 202, 1)",
};
const colorMap600: Record<string, string> = {
  heb: "rgba(37, 99, 235, 1)",
  kaz: "rgba(8, 145, 178, 1)",
  fra: "rgba(2, 132, 199, 1)",
  rus: "rgba(79, 70, 229, 1)",
};
const colorMap500: Record<string, string> = {
  heb: "rgba(59, 130, 246, 1)",
  kaz: "rgba(6, 182, 212, 1)",
  fra: "rgba(14, 165, 233, 1)",
  rus: "rgba(99, 102, 241, 1)",
};
const colorMap400: Record<string, string> = {
  heb: "rgba(96, 165, 250, 1)",
  kaz: "rgba(34, 211, 238, 1)",
  fra: "rgba(56, 189, 248, 1)",
  rus: "rgba(129, 140, 248, 1)",
};
const colorMap300: Record<string, string> = {
  heb: "rgba(147, 197, 253, 1)",
  kaz: "rgba(103, 232, 249, 1)",
  fra: "rgba(125, 211, 252, 1)",
  rus: "rgba(165, 180, 252, 1)",
};
const colorMap200: Record<string, string> = {
  heb: "rgba(191, 219, 254, 1)",
  kaz: "rgba(165, 243, 252, 1)",
  fra: "rgba(186, 230, 253, 1)",
  rus: "rgba(199, 210, 254, 1)",
};
const colorMap100: Record<string, string> = {
  heb: "rgba(219, 234, 254, 1)",
  kaz: "rgba(207, 250, 254, 1)",
  fra: "rgba(224, 242, 254, 1)",
  rus: "rgba(224, 231, 255, 1)",
};
const color800 = colorMap800[language] || "var(--zinc800)";
const color700 = colorMap700[language] || "var(--zinc700)";
const color600 = colorMap600[language] || "var(--zinc600)";
const color500 = colorMap500[language] || "var(--zinc500)";
const color400 = colorMap400[language] || "var(--zinc400)";
const color300 = colorMap300[language] || "var(--zinc300)";
const color200 = colorMap200[language] || "var(--zinc200)";
const color100 = colorMap100[language] || "var(--zinc100)";

const greetingMap: Record<string, string> = {
  heb: "שלום",
  kaz: "Сәлем",
};
const greeting = greetingMap[language] || "Welcome";
---

<style
  define:vars={{
    color800,
    color700,
    color600,
    color500,
    color400,
    color300,
    color200,
    color100,
  }}
>
  .btn {
    border: 1px solid transparent;
    background-color: var(--color200);
  }

  .btn > h3 {
    color: var(--color400);
  }

  .btn:hover {
    border: 1px solid var(--color400);
    background-color: var(--color100);
  }

  .btn:hover > h1,
  .btn:hover > h2,
  .btn:hover > p {
    color: var(--color400);
  }

  .btn:hover > h3 {
    opacity: 1;
    top: 50%;
    right: 1rem;
    transform: translateY(-50%);
  }
</style>

<a href={path}>
  <div class="btn">
    <h1>{title}</h1>
    <h2>{subtitle}</h2>
    <h3>{greeting}</h3>
  </div>
</a>

<style>
  .btn {
    position: relative;
    padding: 1rem;
    width: 100%;
    height: auto;
    margin-bottom: 0.5rem;
    transition: all 0.4s;
    border-radius: 10px;
  }

  .btn > h1 {
    position: relative;
    font-family: "Inter", "Noto Hebrew", sans-serif;
    font-size: 30px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 0rem;
    transition: all 0.4s;
  }

  .btn > h2 {
    font-family: "Noto Korean", sans-serif;
    position: relative;
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--zinc500);
    transition: all 0.4s;
  }

  .btn > h3 {
    font-family: "Inter", "Noto Hebrew", sans-serif;
    position: absolute;
    text-align: center;
    margin: 0;
    top: 60%;
    right: 1rem;
    transform: translateY(-50%);
    font-family: "Inter", "Noto Hebrew", sans-serif;
    width: auto;
    font-size: 24px;
    font-weight: 600;
    color: var(--zinc800);
    opacity: 0;
    transition: all 0.4s;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .btn {
      height: auto;
    }

    .btn > h1 {
      font-size: 20px;
      text-align: center;
    }

    .btn > h2 {
      font-size: 15px;
      font-weight: 500;
      margin-bottom: 0;
      text-align: center;
    }

    .btn > h3 {
      display: none;
    }
  }
</style>
