---
// TableHorizontal.astro

interface Props {
  numberOfColumns: "1" | "2" | "3" | "4";
  data: Record<string, string[]>;
}

const { numberOfColumns, data } = Astro.props;

const object = Object.entries(data)
  .map(([key, value]) => ({ key, value }))
  .slice(0, Number(numberOfColumns));
---

<div class="tableHorizontal">
  {
    object.map(({ key, value }) => (
      <div class="column">
        <div class="columnHeader">
          <p>{key}</p>
        </div>
        {value?.map((row) => (
          <div class="row">
            <p>{row}</p>
          </div>
        ))}
      </div>
    ))
  }
</div>

<style>
  .tableHorizontal {
    display: table;
    table-layout: fixed;
    width: 100%;
    font-family: "Inter", "Noto Hebrew", sans-serif;
    font-weight: 400;
    letter-spacing: 0px;
    margin-bottom: 20px;
    border: 2px solid var(--neutral200);
  }

  .column {
    display: table-cell;
    text-align: left;
    background-color: transparent;
    padding: 10px;
  }

  .columnHeader {
    text-align: center;
    background-color: var(--neutral200);
  }

  .columnHeader > p {
    color: var(--neutral800);
    font-weight: 700;
    font-size: 24px;
    margin: 10px 0;
  }

  .row {
    background-color: transparent;
    margin: 10px 0;
    border: 1px solid transparent;
    transition: 0.3s all;
    border: 2px solid var(--neutral200);
  }

  .row > p {
    color: var(--neutral800);
    font-size: 20px;
    font-weight: 400;
    margin: 10px 0;
    padding-left: 20px;
  }

  .row:hover {
    background-color: var(--neutral200);
  }
</style>
