---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";

interface Props {
  title: string;
  path: string;
  isDev?: string;
}
const { title, path, isDev } = Astro.props;
---

<a href={path}>
  <div class="btn">
    <h1>{title}</h1>
    {isDev && <span>Coming Soon</span>}
  </div>
</a>

<style>
  .btn {
    position: relative;
    background-color: var(--neutral200);
    padding: 0.5rem 1rem;
    width: 100%;
    height: 100%;
    margin-bottom: 1rem;
    transition: all 0.4s;
  }

  .btn:hover {
    background-color: var(--neutral800);
  }

  @keyframes gradient {
    0% {
      background-position: 0% 50%;
    }

    50% {
      background-position: 100% 50%;
    }

    100% {
      background-position: 0% 50%;
    }
  }

  .btn > h1 {
    position: relative;
    font-family: "Roboto Condensed", sans-serif;
    font-size: 24px;
    font-weight: 600;
    text-transform: uppercase;
    margin: 0rem;
    transition: all 0.4s;
  }

  .btn:hover > h1 {
    color: var(--neutral100);
  }

  .btn > span {
    position: absolute;
    display: block;
    top: 80%;
    transform: translateY(-50%);
    right: 1rem;
    font-weight: 600;
    font-size: 18px;
    font-family: "Roboto Condensed", sans-serif;
    text-transform: uppercase;
    color: var(--neutral100);
    opacity: 0;
    transition: 0.4s all;
  }

  .btn:hover > span {
    opacity: 1;
    top: 50%;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .btn {
      margin-bottom: 10px;
    }

    .btn > h1 {
      font-size: 20px;
    }
  }
</style>
