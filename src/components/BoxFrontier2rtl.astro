---
import "../styles/fonts.css";
import "../styles/colors.css";
import "../styles/transition.css";

const { title, subtitle, description, language, eng, fra, deu, rus } =
  Astro.props;

const colorMap800: Record<string, string> = {
  heb: "rgba(30, 64, 175, 1)",
  kaz: "rgba(21, 94, 117, 1)",
};
const colorMap700: Record<string, string> = {
  heb: "rgba(29, 78, 216, 1)",
  kaz: "rgba(14, 116, 144, 1)",
};
const colorMap600: Record<string, string> = {
  heb: "rgba(37, 99, 235, 1)",
  kaz: "rgba(8, 145, 178, 1)",
};
const colorMap500: Record<string, string> = {
  heb: "rgba(59, 130, 246, 1)",
  kaz: "rgba(6, 182, 212, 1)",
};
const colorMap400: Record<string, string> = {
  heb: "rgba(96, 165, 250, 1)",
  kaz: "rgba(34, 211, 238, 1)",
};
const colorMap300: Record<string, string> = {
  heb: "rgba(147, 197, 253, 1)",
  kaz: "rgba(103, 232, 249, 1)",
};
const colorMap200: Record<string, string> = {
  heb: "rgba(191, 219, 254, 1)",
  kaz: "rgba(165, 243, 252, 1)",
};
const colorMap100: Record<string, string> = {
  heb: "rgba(219, 234, 254, 1)",
  kaz: "rgba(207, 250, 254, 1)",
};
const color800 = colorMap800[language] || "var(--zinc800)";
const color700 = colorMap700[language] || "var(--zinc700)";
const color600 = colorMap600[language] || "var(--zinc600)";
const color500 = colorMap500[language] || "var(--zinc500)";
const color400 = colorMap400[language] || "var(--zinc400)";
const color300 = colorMap300[language] || "var(--zinc300)";
const color200 = colorMap200[language] || "var(--zinc200)";
const color100 = colorMap100[language] || "var(--zinc100)";
---

<style
  define:vars={{
    color800,
    color700,
    color600,
    color500,
    color400,
    color300,
    color200,
    color100,
  }}
>
  .box {
    background-color: var(--color200);
  }

  .box > h2,
  .box > h3,
  .box > p {
    color: var(--neutral800);
  }
</style>

<div class="box">
  <h2 class="riseUp_2">{title}</h2>
  {subtitle && <h3 class="riseUp_3">{subtitle}</h3>}
</div>

<style>
  .box {
    position: relative;
    display: block;
    padding: 1.5rem;
    width: 100%;
    aspect-ratio: 1 / 1;
    height: 300px;
    margin-bottom: 2rem;
    outline: none;
    z-index: 0;
    text-decoration: none;
    background-color: transparent;
    border-radius: 20px;
    transition: all 1s cubic-bezier(0.19, 1, 0.22, 1);
  }

  .box > h2 {
    position: relative;
    font-family: "Inter", "Noto Hebrew", sans-serif;
    text-transform: uppercase;
    display: inline;
    font-size: 40px;
    font-weight: 600;
    line-height: 1.1;
    word-break: keep-all;
    word-wrap: break-word;
    transition: all 0.4s;
    direction: rtl;
  }

  .box > h3 {
    position: relative;
    font-family: "Noto Korean", sans-serif;
    display: inline-box;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0px;
    line-height: 1.1;
    margin-top: 10px;
    margin-bottom: 0;
    transition: all 0.4s;
  }

  .box > p {
    position: absolute;
    display: block;
    width: 100%;
    bottom: 0;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0px;
    line-height: 1;
    margin-top: 10px;
    transition: all 0.4s;
  }

  .box > h2,
  .box > h3,
  .box > p {
    color: var(--zinc800);
  }

  /* Mobile */
  @media (max-width: 480px) {
    .box > h2 {
      font-size: 28px;
    }

    .box > h3 {
      font-size: 16px;
    }
  }
</style>
