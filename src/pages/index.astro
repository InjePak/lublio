---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonMain from "../components/ButtonMain.astro";
import Typewriter from "../components/Typewriter.astro";

// Logo
import LogoSVG from "../../public/lublio-logo-light.svg?raw";

const pageTitle = "Lublio";
---

<BaseLayout pageTitle={pageTitle}>
  <div class="icon-wrapper">
    <a href="/">
      <Fragment set:html={LogoSVG} />
    </a>
  </div>

  <h2>
    <Typewriter
      texts={[
        "Beyond just 'Bonjour',", // [프랑스어] 단순히 '봉주르'를 넘어,
        "A 'Ciao' that leads to friendship,", // [이탈리아어] 우정으로 이어지는 '챠오',
        "Finding your 'Buen Camino',", // [스페인어] 당신만의 '좋은 길(여정)'을 찾는,
        "More than a 'Danke' in Berlin,", // [독일어] 베를린에서의 '당케' 그 이상의 진심,
        "The 'Saudade' of Lisbon streets,", // [포르투갈어] 리스본 거리의 '그리움(사우다드)',
        "Whispering 'Ahoj' in Prague,", // [체코어] 프라하에서 '안녕(아호이)'이라고 속삭이는,
        "A 'Fiesta' that never ends,", // [스페인어] 끝나지 않는 '축제',
        "Every 'Oui' is a new beginning,", // [프랑스어] 모든 '응(위)'은 새로운 시작,
      ]}
    />
  </h2>
  <h2 id="fixed-title">start your journey here.</h2>

  <div class="button-wrapper">
    <ButtonMain
      title="Français"
      subtitle="French"
      description="CEFR A1-C1"
      language="fra"
      path="/french"
    />

    <ButtonMain
      title="Español"
      subtitle="Spanish"
      description="CEFR A1 - C1"
      language="esp"
      path="/spanish"
    />

    <ButtonMain
      title="Deutsch"
      subtitle="German"
      description="CEFR A1 - C1"
      language="deu"
      path="/german"
    />

    <ButtonMain
      title="Italiano"
      subtitle="Italian"
      description="CEFR A1 - C1"
      language="ita"
      path="/italian"
    />

    <ButtonMain
      title="Русский"
      subtitle="Russian"
      description="CEFR A1-C1"
      language="rus"
      path="/russian"
    />

    <!-- 
        <ButtonMain
        title="Čeština"
        subtitle="체코어"
        description="CEFR A1 - C1"
        language="ces"
        path="/czech"
        />
        
        <ButtonMain
        title="Magyar"
        subtitle="헝가리어"
        description="CEFR A1 - C1"
        language="hun"
        path="/hungarian"
        />
        
        <ButtonMain
        title="Türkçe"
        subtitle="튀르키예어"
        description="CEFR A1 - C1"
        language="tur"
        path="/turkish"
        />
        </div> -->
  </div>

  <style>
    .icon-wrapper {
      position: relative;
      width: 60px; /* 원하는 크기 조절 */
      padding-top: 10px;
      padding-left: 10px;
      padding-right: 10px;
      padding-bottom: 5px;
      height: auto;
      margin-left: auto;
      border-bottom: 2px solid transparent;
      transition: 0.4s all;
    }

    /* SVG 내부의 path나 circle 등을 직접 제어 */
    .icon-wrapper :global(svg) {
      width: 100%;
      height: 100%;
    }

    /* 호버 시 색상 변경 예시 */
    .icon-wrapper:hover {
      cursor: pointer;
      background-color: var(--neutral200);
    }

    h2 {
      font-family: "Inter", sans-serif;
      margin-top: 150px;
      font-size: 28px;
      line-height: 30px;
      margin-bottom: 0.5rem;
      font-weight: 400;
    }

    #fixed-title {
      font-family: "Roboto Condensed", sans-serif;
      margin-top: 0px;
      text-transform: uppercase;
      font-size: 40px;
      line-height: 40px;
      margin-bottom: 2rem;
      font-weight: 700;
    }

    .button-wrapper {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    /* Mobile */
    @media (max-width: 480px) {
      .icon-wrapper {
        width: 50px; /* 원하는 크기 조절 */
      }

      h3 {
        margin-top: 100px;
        font-size: 20px;
        line-height: 20px;
      }

      h2 {
        margin-top: 100px;
        font-size: 20px;
        line-height: 20px;
      }

      .button-wrapper {
        gap: 20px;
      }
    }
  </style>
</BaseLayout>
