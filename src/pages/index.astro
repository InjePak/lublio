---
import FrontierLayout from "../layouts/FrontierLayout.astro";
import ButtonMainFrontier from "../components/ButtonMainFrontier.astro";
import Typewriter from "../components/Typewriter.astro";

// Logo
import LogoSVG from "../../public/lublio-logo-dark.svg?raw";

const pageTitle = "Lublio";
---

<FrontierLayout pageTitle={pageTitle}>
  <div class="icon-wrapper">
    <a href="/">
      <Fragment set:html={LogoSVG} />
    </a>
  </div>

  <h2>
    <!-- <Typewriter
      texts={[
        "두려움보다 설렘을 선택한",
        "작은 시작으로 큰 변화를 이끄는",
        "자신만의 우주를 펼쳐가는",
        "오늘보다 나은 내일을 만드는",
        "스스로 길을 만들어가는",
        "일상이 곧 모험인",
        "매일 새로운 나를 발견하는",
        "세상에 없던 길을 그려가는",
        "어제의 나를 뛰어넘는",
        "불가능을 가능으로 바꾸는",
      ]}
    /> -->
  </h2>

  <h2 id="fixed-title">Start your journey here.</h2>

  <div class="button-wrapper">
    <ButtonMainFrontier
      title="Germano"
      subtitle="Deutsch"
      description="German learning project"
      language="deu"
      path="/germano"
    />

    <ButtonMainFrontier
      title="Franco"
      subtitle="Français"
      description="French learning project"
      language="fra"
      path="/franco"
    />

    <!-- <ButtonMainFrontier
      title="Russo"
      subtitle="Русский"
      description="Russian learning project"
      language="rus"
      path="/russo"
    /> -->

    <!-- <ButtonMainFrontier
      title="Ivriah"
      subtitle="이브리아"
      description="히브리어 프로젝트"
      language="heb"
      path="/ivriah"
    />

    <ButtonMainFrontier
      title="Kazariah"
      subtitle="카자리아"
      description="카자흐어 프로젝트"
      language="kaz"
      path="/kazariah"
    /> -->

    <!-- <ButtonMainFrontier
      title="Italiano"
      subtitle="Italian"
      description="CEFR A1-C1"
      language="ita"
      path="/italian"
    /> -->

    <!-- <ButtonMainFrontier
    title="Español"
    subtitle="Spanish"
    description="CEFR A1-C1"
    language="spa"
    path="/spanish"
    />
    
    <ButtonMainFrontier
      title="Nederlands"
      subtitle="Dutch"
      description="CEFR A1-C1"
      language="nld"
      path="/dutch"
    /> -->
  </div>

  <style>
    .icon-wrapper {
      position: relative;
      width: 50px;
      padding-top: 10px;
      padding-left: 10px;
      padding-right: 10px;
      padding-bottom: 5px;
      height: auto;
      margin-left: auto;
      border-bottom: 2px solid transparent;
      transition: 0.4s all;
    }

    .icon-wrapper :global(svg) {
      width: 100%;
      height: 100%;
    }

    .icon-wrapper:hover {
      cursor: pointer;
      background-color: var(--neutral800);
    }

    h2 {
      font-family: "Roboto Condensed", sans-serif;
      margin-top: 150px;
      font-size: 24px;
      line-height: 34px;
      margin-bottom: 0.5rem;
      font-weight: 500;
    }

    #fixed-title {
      font-family: "Roboto Condensed", sans-serif;
      margin-top: 0px;
      text-transform: uppercase;
      font-size: 40px;
      line-height: 40px;
      margin-bottom: 2rem;
      font-weight: 600;
    }

    .button-wrapper {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    /* Mobile */
    @media (max-width: 480px) {
      .icon-wrapper {
        width: 50px;
      }

      h3 {
        margin-top: 100px;
        font-size: 20px;
        line-height: 20px;
      }

      h2 {
        height: 30px;
        margin-top: 120px;
        font-size: 20px;
        line-height: 18px;
        margin-bottom: 0px;
      }

      #fixed-title {
        font-size: 36px;
        height: 24px;
        margin-bottom: 5rem;
      }

      .button-wrapper {
        gap: 10px;
      }
    }
  </style>
</FrontierLayout>
