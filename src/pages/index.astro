---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonMain from "../components/ButtonMain.astro";
import Typewriter from "../components/Typewriter.astro";

// Logo
import LogoSVG from "../../public/lublio-logo-light.svg?raw";

const pageTitle = "Lublio";
---

<BaseLayout pageTitle={pageTitle}>
  <div class="icon-wrapper">
    <a href="/">
      <Fragment set:html={LogoSVG} />
    </a>
  </div>

  <h2>
    <Typewriter
      texts={[
        "Choosing wonder over worry",
        "Writing a story only you can tell",
        "Finding beauty in the becoming",
        "Turning small steps into quiet revolutions",
        "Living at the edge of your own potential",
        "Discovering who you are through what you do",
        "Making peace with the pace of your journey",
        "Letting curiosity lead the way",
        "Crafting a life that feels like yours",
        "Growing in directions you never expected",
      ]}
    />
  </h2>
  <h2 id="fixed-title">We're rooting for you ✨</h2>

  <div class="button-wrapper">
    <ButtonMain
      title="Germano"
      subtitle="German"
      description="CEFR A1 - C1"
      language="deu"
      path="/germano"
    />

    <ButtonMain
      title="Franco"
      subtitle="French"
      description="CEFR A1 - C1"
      language="fra"
      path="/franco"
    />

    <ButtonMain
      title="Russo"
      subtitle="Russian"
      description="CEFR A1 - C1"
      language="rus"
      path="/russo"
    />

    <!-- <ButtonMain
    title="Español"
    subtitle="Spanish"
    description="CEFR A1-C1"
    language="spa"
    path="/spanish"
    />
    
    <ButtonMain
    title="Italiano"
    subtitle="Italian"
    description="CEFR A1-C1"
      language="ita"
      path="/italian"
    />

    <ButtonMain
      title="Nederlands"
      subtitle="Dutch"
      description="CEFR A1-C1"
      language="nld"
      path="/dutch"
    /> -->
  </div>

  <style>
    .icon-wrapper {
      position: relative;
      width: 60px;
      padding-top: 10px;
      padding-left: 10px;
      padding-right: 10px;
      padding-bottom: 5px;
      height: auto;
      margin-left: auto;
      border-bottom: 2px solid transparent;
      transition: 0.4s all;
    }

    .icon-wrapper :global(svg) {
      width: 100%;
      height: 100%;
    }

    .icon-wrapper:hover {
      cursor: pointer;
      background-color: var(--neutral200);
    }

    h2 {
      font-family: "Inter", sans-serif;
      margin-top: 150px;
      font-size: 24px;
      line-height: 34px;
      margin-bottom: 0.5rem;
      font-weight: 600;
    }

    #fixed-title {
      font-family: "Roboto Condensed", sans-serif;
      margin-top: 0px;
      text-transform: uppercase;
      font-size: 40px;
      line-height: 40px;
      margin-bottom: 2rem;
      font-weight: 700;
    }

    .button-wrapper {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    /* Mobile */
    @media (max-width: 480px) {
      .icon-wrapper {
        width: 50px;
      }

      h3 {
        margin-top: 100px;
        font-size: 20px;
        line-height: 20px;
      }

      h2 {
        height: 30px;
        margin-top: 120px;
        font-size: 20px;
        line-height: 22px;
        width: 85%;
      }

      #fixed-title {
        height: 70px;
        margin-top: 1rem;
        margin-bottom: 2rem;
      }

      .button-wrapper {
        gap: 10px;
      }
    }
  </style>
</BaseLayout>
