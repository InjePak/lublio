---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonMain from "../components/ButtonMain.astro";
import Typewriter from "../components/Typewriter.astro";

// Logo
import LogoSVG from "../../public/lublio-logo-light.svg?raw";

const pageTitle = "Lublio";
---

<BaseLayout pageTitle={pageTitle}>
  <div class="icon-wrapper">
    <a href="/">
      <Fragment set:html={LogoSVG} />
    </a>
  </div>

  <h2>
    <Typewriter
      texts={[
        "두려움보다 설렘을 선택한",
        "작은 시작으로 큰 변화를 이끄는",
        "자신만의 우주를 펼쳐가는",
        "오늘보다 나은 내일을 만드는",
        "스스로 길을 만들어가는",
        "일상이 곧 모험인",
        "매일 새로운 나를 발견하는",
        "세상에 없던 길을 그려가는",
        "어제의 나를 뛰어넘는",
        "불가능을 가능으로 바꾸는",
      ]}
    />
  </h2>

  <h2 id="fixed-title">여러분을 응원합니다 ✨</h2>

  <div class="button-wrapper">
    <ButtonMain
      title="Franco"
      subtitle="프로젝트 프랑코"
      description="프랑스어 학습 블로그"
      language="fra"
      path="/franco"
    />

    <ButtonMain
      title="Russo"
      subtitle="프로젝트 루소"
      description="러시아어 학습 블로그"
      language="rus"
      path="/russo"
    />

    <!-- <ButtonMain
      title="Español"
      subtitle="Spanish"
      description="CEFR A1-C1"
      language="spa"
      path="/spanish"
    />

    <ButtonMain
      title="Deutsch"
      subtitle="German"
      description="CEFR A1 - C1"
      language="deu"
      path="/german"
    />

    <ButtonMain
      title="Italiano"
      subtitle="Italian"
      description="CEFR A1-C1"
      language="ita"
      path="/italian"
    />

    <ButtonMain
      title="Nederlands"
      subtitle="Dutch"
      description="CEFR A1-C1"
      language="nld"
      path="/dutch"
    /> -->
  </div>

  <style>
    .icon-wrapper {
      position: relative;
      width: 60px; /* 원하는 크기 조절 */
      padding-top: 10px;
      padding-left: 10px;
      padding-right: 10px;
      padding-bottom: 5px;
      height: auto;
      margin-left: auto;
      border-bottom: 2px solid transparent;
      transition: 0.4s all;
    }

    /* SVG 내부의 path나 circle 등을 직접 제어 */
    .icon-wrapper :global(svg) {
      width: 100%;
      height: 100%;
    }

    /* 호버 시 색상 변경 예시 */
    .icon-wrapper:hover {
      cursor: pointer;
      background-color: var(--neutral200);
    }

    h2 {
      font-family: "Inter", sans-serif;
      margin-top: 150px;
      font-size: 24px;
      line-height: 34px;
      margin-bottom: 0.5rem;
      font-weight: 600;
    }

    #fixed-title {
      font-family: "Roboto Condensed", sans-serif;
      margin-top: 0px;
      text-transform: uppercase;
      font-size: 40px;
      line-height: 40px;
      margin-bottom: 2rem;
      font-weight: 700;
    }

    .button-wrapper {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    /* Mobile */
    @media (max-width: 480px) {
      .icon-wrapper {
        width: 50px; /* 원하는 크기 조절 */
      }

      h3 {
        margin-top: 100px;
        font-size: 20px;
        line-height: 20px;
      }

      h2 {
        height: 30px;
        margin-top: 120px;
        font-size: 20px;
        line-height: 22px;
        width: 85%;
      }

      #fixed-title {
        height: 70px;
        margin-top: 1rem;
        margin-bottom: 2rem;
      }

      .button-wrapper {
        gap: 10px;
      }
    }
  </style>
</BaseLayout>
