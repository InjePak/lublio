---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonMain from "../components/ButtonMain.astro";
import Typewriter from "../components/Typewriter.astro";

// Logo
import LogoSVG from "../../public/lublio-logo-light.svg?raw";

const pageTitle = "Lublio";
---

<BaseLayout pageTitle={pageTitle}>
  <div class="icon-wrapper">
    <a href="/">
      <Fragment set:html={LogoSVG} />
    </a>
  </div>
  <h2>
    <Typewriter
      texts={[
        "스스로 길을 만들어가는",
        "일상이 곧 모험인",
        "두려움보다 설렘을 선택한",
        "매일 새로운 나를 발견하는",
        "세상에 없던 길을 그려가는",
        "포기 대신 한 걸음을 택한",
        "어제의 나를 뛰어넘는",
        "자신만의 우주를 펼쳐가는",
        "오늘보다 나은 내일을 만드는",
      ]}
    />
    <br />
    당신을 응원합니다.
  </h2>

  <!-- <ButtonMain
    title="English"
    subtitle="영어"
    description="CEFR A1 - C1"
    language="eng"
    path="/english"
  /> -->

  <ButtonMain
    title="Deutsch"
    subtitle="독일어"
    description="CEFR A1 - C1"
    language="deu"
    path="/german"
  />

  <ButtonMain
    title="Français"
    subtitle="프랑스어"
    description="CEFR A1 - C1"
    language="fra"
    path="/french"
  />

  <ButtonMain
    title="Русский"
    subtitle="러시아어"
    description="CEFR A1 - C1"
    language="rus"
    path="/russian"
  />
</BaseLayout>

<style>
  .icon-wrapper {
    position: relative;
    width: 60px; /* 원하는 크기 조절 */
    padding-top: 10px;
    padding-left: 10px;
    padding-right: 10px;
    padding-bottom: 5px;
    height: auto;
    margin-left: auto;
    border-bottom: 2px solid transparent;
    transition: 0.4s all;
  }

  /* SVG 내부의 path나 circle 등을 직접 제어 */
  .icon-wrapper :global(svg) {
    width: 100%;
    height: 100%;
  }

  /* 호버 시 색상 변경 예시 */
  .icon-wrapper:hover {
    cursor: pointer;
    background-color: var(--neutral200);
  }

  h2 {
    font-family: "Noto Korean", sans-serif;
    margin-top: 100px;
    font-size: 50px;
    line-height: 60px;
    margin-bottom: 2rem;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .icon-wrapper {
      width: 50px; /* 원하는 크기 조절 */
    }

    h2 {
      margin-top: 100px;
      font-size: 25px;
      line-height: 35px;
    }
  }
</style>
