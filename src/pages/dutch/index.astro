---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Box from "../../components/Box.astro";
import Button from "../../components/Button.astro";

const pageTitle = "Dutch";
---

<BaseLayout pageTitle={pageTitle + " - Lublio"}>
  <Box
    title="Nederlands"
    subtitle="Dutch"
    description="Nederlands is de taal van innovatie, handel en de iconische grachten. Met zijn nuchtere karakter en wereldwijde invloed opent het de deuren naar een rijk historisch erfgoed en een moderne, open samenleving die bekend staat om zijn 'gezelligheid'."
    language="nld"
  />

  <div class="button-wrapper">
    <Button
      title="Zinnen"
      subtitle="Phrasebook"
      description="CEFR A1 - B2"
      language="nld"
      path="/dutch/phrasebook"
      level="phrase"
    />

    <Button
      title="Patronen"
      subtitle="Patterns"
      description="CEFR B1 - C1"
      language="nld"
      path="/dutch/pattern"
      level="pattern"
    />

