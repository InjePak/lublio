---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Box from "../../../components/Box.astro";
import Button2 from "../../../components/Button2.astro";

import chapters from "../../../assets/json/patterns/chapters.json";

const pageTitle = "Dutch Sentence Patterns";
---

<BaseLayout pageTitle={pageTitle + " - Lublio"}>
  <Box
    title="Patronen"
    subtitle="Sentence Patterns"
    description="Create tens of thousands of sentences with just one pattern, without complicated thinking. Experience the most efficient learning that gets you speaking quickly."
    language="nld"
  />

  {
    chapters.map((post: any) => (
      <Button2
        id={post.id}
        title={post.nld}
        subtitle={post.eng}
        language="nld"
        path={"/dutch/pattern/" + post.path}
      />
    ))
  }
</BaseLayout>
