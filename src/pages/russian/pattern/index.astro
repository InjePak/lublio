---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Box from "../../../components/Box.astro";
import Button2 from "../../../components/Button2.astro";

import chapters from "../../../assets/json/patterns/chapters.json";

const pageTitle = "Russian Sentence Patterns";
---

<BaseLayout pageTitle={pageTitle + " | Lublio"}>
  <Box
    title="Схемы"
    subtitle="Sentence Patterns"
    description="Create tens of thousands of sentences using just a single pattern, without any complicated thinking. Experience the most efficient way to quickly improve your speaking skills."
    language="rus"
  />

  {
    chapters.map((post: any) => (
      <Button2
        id={post.id}
        title={post.rus}
        subtitle={post.eng}
        language="rus"
        path={"/russian/pattern/" + post.path}
      />
    ))
  }
</BaseLayout>
