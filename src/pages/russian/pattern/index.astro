---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Box2 from "../../../components/Box2.astro";
import Button2 from "../../../components/Button2.astro";

import chapters from "../../../assets/json/patterns/chapters.json";

const pageTitle = "러시아어";
---

<BaseLayout pageTitle={pageTitle + " | Lublio"}>
  <Box2
    title="러시아어 패턴"
    subtitle="Полезные фразы"
    description="Русский язык — это язык великой литературы и космоса. Обладая богатой грамматикой и выразительностью, он открывает доступ к глубокой культуре и истории крупнейшей страны мира."
    language="rus"
  />

  {
    chapters.map((post: any) => (
      <Button2
        id={post.id}
        title={post.rus}
        subtitle={post.kor}
        language="rus"
        path={"/russian/pattern/" + post.path}
      />
    ))
  }
</BaseLayout>
