}

const pageTitle = "러시아어 회화";
---

<BaseLayout pageTitle={pageTitle + " | Lublio"}>
  <div class="title">
    <h1 class="riseUp_1">{chapter.kor}</h1>
    <hr />
    <p class="riseUp_2">{chapter.rus}</p>
  </div>

  {
    !jsonData ? (
      <p>서버 에러입니다.</p>
    ) : (
      jsonData.map((data: any, index: number) => (
        <div class="phrase-box">
          <h2>
            {index + 1}. {data.kor}
          </h2>
          <hr />
          <p>
            <span style="color: var(--indigo400)">●</span>
            {data.rus}
          </p>
        </div>
      ))
    )
  }
</BaseLayout>

<style>
  /* Title */

  .title {
    background-color: var(--indigo400);
    padding: 1.5rem 2rem;
    margin-bottom: 1.5rem;
    border-radius: 20px;
  }

  .title > h1,
  .title > p {
    width: 100%;
  }

  .title > h1 {
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .title > p {
    color: var(--zinc800);
    font-weight: 500;
    margin-bottom: 0rem;
  }

  .title > p:last-child {
    margin-bottom: 0;
  }

  .title > hr {
    border: 1px solid var(--zinc800);
    margin: 1.5rem 0;
  }

  /* Phrase Box */

  .phrase-box {
    border: 1px solid var(--zinc400);
    margin-bottom: 1.5rem;
    padding: 1.5rem;
  }

  .phrase-box > h2 {
    font-size: 20px;
    font-weight: 500;
    margin-top: 1.5rem;
  }

  .phrase-box > hr {
    border: 1px solid var(--zinc800);
    margin: 0;
    margin-bottom: 1.5rem;
  }

  .phrase-box > p {
    font-size: 17px;
    margin-bottom: 1.5rem;
  }

  .phrase-box > p > span {
    margin-right: 10px;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .title {
      background-color: var(--amber400);
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .title > h1,
    .title > p {
      width: 100%;
    }

    .title > h1 {
      font-size: 22px;
    }

    .title > p {
      font-size: 15px;
    }

    .phrase-box > h2 {
      font-size: 16px;
      margin-top: 1rem;
    }

    .phrase-box > p {
      font-size: 15px;
      margin-bottom: 1.2rem;
      line-height: 1.5rem;
    }
  }
</style>
