---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Box from "../../../components/Box.astro";
import Button2 from "../../../components/Button2.astro";
import SectionSwitcher from "../../../components/SectionSwitcher.astro";

import chapters from "../../../assets/json/phrasebook/chapters.json";
const chapters_a1 = chapters["a1"];
const chapters_a2 = chapters["a2"];
const chapters_b1 = chapters["b1"];
const chapters_b2 = chapters["b2"];

// Title
const pageTitle = "Russian Phrasebook";

// Section Switcher
const tabItems = [
  { id: "group-a1", label: "A1" },
  { id: "group-a2", label: "A2" },
  { id: "group-b1", label: "B1" },
  { id: "group-b2", label: "B2" },
];
---

<BaseLayout pageTitle={pageTitle + " | Lublio"}>
  <Box
    title="Фразы"
    subtitle="Russian Phrasebook"
    description="A direct gaze, a resonant Привет, and the kind of exchange that doesn't waste a single word. Russian is a language of weight and warmth — where every phrase holds its ground, and the simplest greeting carries the soul of something much larger."
    language="rus"
  />

  <SectionSwitcher items={tabItems} />

  <main>
    <section class="group-a1">
      <h2>
        <span class="animated-underline-rus">CEFR A1</span>
      </h2>
      <ul>
        {
          chapters_a1.map((post: any) => (
            <Button2
              id={post.id}
              title={post.rus}
              subtitle={post.eng}
              language="rus"
              path={"/russian/phrasebook/a1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section class="group-a2">
      <h2>
        <span class="animated-underline-rus">CEFR A2</span>
      </h2>
      <ul>
        {
          chapters_a2.map((post: any) => (
            <Button2
              id={post.id}
              title={post.rus}
              subtitle={post.eng}
              language="rus"
              path={"/russian/phrasebook/a2/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section class="group-b1">
      <h2>
        <span class="animated-underline-rus">CEFR B1</span>
      </h2>
      <ul>
        {
          chapters_b1.map((post: any) => (
            <Button2
              id={post.id}
              title={post.rus}
              subtitle={post.eng}
              language="rus"
              path={"/russian/phrasebook/b1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section class="group-b2">
      <h2>
        <span class="animated-underline-rus">CEFR B2</span>
      </h2>
      <ul>
        {
          chapters_b2.map((post: any) => (
            <Button2
              id={post.id}
              title={post.rus}
              subtitle={post.eng}
              language="rus"
              path={"/russian/phrasebook/b2/" + post.path}
            />
          ))
        }
      </ul>
    </section>
  </main>
</BaseLayout>

<style>
  section {
    padding-top: 1.5rem;
  }
</style>
