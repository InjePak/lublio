---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Box from "../../../components/Box.astro";
import Button from "../../../components/Button.astro";

// Title
const pageTitle = "Russian Grammar";
---

<BaseLayout pageTitle={pageTitle + " | Lublio"}>
  <Box
    title="Грамматика"
    subtitle="Russian Grammar"
    description="The clearest roadmap for turning your thoughts into sentences. Build unwavering speaking skills on a rock-solid grammatical foundation."
    language="rus"
  />

  <Button
    title="Абсолютный новичок"
    subtitle="Absolute beginner"
    description="CEFR A0"
    language="rus"
    path="/russian/a0"
    level="a0"
    isDev="true"
  />

  <Button
    title="Элементарный"
    subtitle="Beginner"
    description="CEFR A1"
    language="rus"
    path="/russian/a1"
    level="a1"
    isDev="true"
  />

  <Button
    title="Предпороговый"
    subtitle="Elementary"
    description="CEFR A2"
    language="rus"
    path="/russian/a2"
    level="a2"
    isDev="true"
  />

  <Button
    title="Пороговый"
    subtitle="Intermediate"
    description="CEFR B1"
    language="rus"
    path="/russian/b1"
    level="b1"
    isDev="true"
  />

  <Button
    title="Постпороговый"
    subtitle="Upper Intermediate"
    description="CEFR B2"
    language="rus"
    path="/russian/b2"
    level="b2"
    isDev="true"
  />
</BaseLayout>

<style>
  section {
    padding-top: 1.5rem;
  }
</style>
