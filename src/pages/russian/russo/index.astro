---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Box from "../../../components/Box.astro";
import Button from "../../../components/Button.astro";

const pageTitle = "종합 러시아어";
---

<BaseLayout pageTitle={pageTitle + " - Lublio"}>
  <Box
    title="Russo"
    subtitle="종합 러시아어"
    description="러시아어는 광활한 서사와 철학적 고뇌를 담아내는 영혼의 언어입니다. 독보적인 지적 아우라를 지닌 루소폰(Russophone) 거듭나는 지적 여정을 시작해볼까요?"
    language="rus"
  />

  <Button
    title="Абсолютный новичок"
    subtitle="러시아어 첫걸음"
    description="CEFR A0"
    language="rus"
    path="/russian/russo/a0"
    level="a0"
    isDev="true"
  />

  <Button
    title="Начинающий"
    subtitle="기초 러시아어"
    description="CEFR A1"
    language="rus"
    path="/russian/russo/a1"
    level="a1"
    isDev="true"
  />

  <Button
    title="Элементарный"
    subtitle="초급 러시아어"
    description="CEFR A2"
    language="rus"
    path="/russian/russo/a2"
    level="a2"
    isDev="true"
  />

  <Button
    title="Средний"
    subtitle="중급 러시아어"
    description="CEFR B1"
    language="rus"
    path="/russian/russo/b1"
    level="b1"
    isDev="true"
  />

  <Button
    title="Выше среднего"
    subtitle="중고급 러시아어"
    description="CEFR B2"
    language="rus"
    path="/russian/russo/b2"
    level="b2"
    isDev="true"
  />
</BaseLayout>
