---
import RussianLayout from "../../layouts/RussianLayout.astro";
import BoxMainFrontier from "../../components/BoxMainFrontier.astro";
import ButtonFrontier from "../../components/ButtonFrontier.astro";

const pageTitle = "러시아어";
---

<RussianLayout pageTitle={pageTitle + " | Lublio"}>
  <BoxMainFrontier
    title="Русский"
    subtitle="러시아어"
    description="러시아어는 대륙만큼 넓고 겨울만큼 깊은 언어입니다. 톨스토이와 도스토옙스키가 그 문장들로 인간의 내면을 파헤쳤고, 오늘날에도 유라시아 전역에서 수억 명의 목소리를 잇고 있습니다. 압도적인 스케일과 섬세함을 동시에 품은 언어, 지금 만나보세요."
    language="rus"
  />

  <div class="buttonFrontier-wrapper">
    <!-- <ButtonFrontier
      title="Грамматика"
      subtitle="Grammar"
      description="CEFR A1 - B2"
      language="rus"
      path="/russian/grammar"
      level="grammar"
      isDev="true"
    /> -->

    <ButtonFrontier
      title="Фразы"
      subtitle="러시아어 회화"
      description="CEFR A1 - B2"
      language="rus"
      path="/russian/phrasebook"
      level="phrase"
    />

    <ButtonFrontier
      title="Схемы"
      subtitle="러시아어 패턴"
      description="CEFR B1 - C1"
      language="rus"
      path="/russian/pattern"
      level="pattern"
    />

    <!-- <ButtonFrontier
      title="Словарь"
      subtitle="Vocabulary"
      description="CEFR A1 - C1"
      language="rus"
      path="/russian/vocabulary"
      level="vocabulary"
      isDev="true"
    /> -->
  </div>
</RussianLayout>

<style>
  .buttonFrontier-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .buttonFrontier-wrapper {
      gap: 10px;
      margin-bottom: 10px;
    }
  }
</style>
