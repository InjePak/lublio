---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Box from "../../components/Box.astro";
import Button from "../../components/Button.astro";

const pageTitle = "Russian";
---

<BaseLayout pageTitle={pageTitle + " | Lublio"}>
  <Box
    title="Русский"
    subtitle="Russian"
    description="Русский — это язык великой литературы и космоса. Обладая невероятной силой выражения и эмоциональной глубиной, он открывает доступ к богатейшему культурному наследию и передовым научным достижениям."
    language="rus"
  />

  <div class="button-wrapper">
    <!-- <Button
      title="Грамматика"
      subtitle="Grammar"
      description="CEFR A1 - B2"
      language="rus"
      path="/russian/grammar"
      level="grammar"
      isDev="true"
    /> -->

    <Button
      title="Фразы"
      subtitle="Phrasebook"
      description="CEFR A1 - B2"
      language="rus"
      path="/russian/phrasebook"
      level="phrase"
    />

    <Button
      title="Схемы"
      subtitle="Sentence Patterns"
      description="CEFR B1 - C1"
      language="rus"
      path="/russian/pattern"
      level="pattern"
    />

    <!-- <Button
      title="Словарь"
      subtitle="Vocabulary"
      description="CEFR A1 - C1"
      language="rus"
      path="/russian/vocabulary"
      level="vocabulary"
      isDev="true"
    /> -->
  </div>
</BaseLayout>

<style>
  .button-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .button-wrapper {
      gap: 10px;
      margin-bottom: 10px;
    }
  }
</style>
