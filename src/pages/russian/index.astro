---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Box from "../../components/Box.astro";
import Button from "../../components/Button.astro";

const pageTitle = "러시아어";
---

<BaseLayout pageTitle={pageTitle + " - Lublio"}>
  <Box
    title="Русский"
    subtitle="러시아어"
    description="Русский язык — это язык великой литературы и космоса. Обладая богатой грамматикой и выразительностью, он открывает доступ к глубокой культуре и истории крупнейшей страны мира."
    language="rus"
  />

  <div class="button-wrapper">
    <Button
      title="Фразы"
      subtitle="러시아어 회화"
      description="CEFR A1 - B2"
      language="rus"
      path="/russian/phrasebook"
      level="phrase"
    />

    <Button
      title="Схемы"
      subtitle="러시아어 패턴"
      description="CEFR B1 - C1"
      language="rus"
      path="/russian/pattern"
      level="pattern"
    />

    <!-- <Button
      title="Russo"
      subtitle="종합 러시아어"
      description="CEFR A0 - B2"
      language="rus"
      path="/russian/russo"
      level="composite"
      isDev="true"
    /> -->
  </div>

  <!-- <Button
    title="Грамматика"
    subtitle="러시아어 문법"
    description="CEFR A1 - B2"
    language="rus"
    path="/russian/grammar"
    level="grammar"
    isDev="true"
  /> -->
</BaseLayout>

<style>
  .button-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    justify-items: stretch;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .button-wrapper {
      gap: 10px;
      margin-bottom: 10px;
    }
  }
</style>
