---
import IvriahLayout from "../../../layouts/IvriahLayout.astro";
import BoxFrontier2rtl from "../../../components/BoxFrontier2rtl.astro";
import ButtonFrontier2rtl from "../../../components/ButtonFrontier2rtl.astro";

import chapters from "../../../assets/json/patterns/chapters.json";
import chapter1 from "../../../assets/json/patterns/hebrew/chapter1.json";
import chapter2 from "../../../assets/json/patterns/hebrew/chapter2.json";
import chapter3 from "../../../assets/json/patterns/hebrew/chapter3.json";
import chapter4 from "../../../assets/json/patterns/hebrew/chapter4.json";
import chapter5 from "../../../assets/json/patterns/hebrew/chapter5.json";
import chapter6 from "../../../assets/json/patterns/hebrew/chapter6.json";
import chapter7 from "../../../assets/json/patterns/hebrew/chapter7.json";
import chapter8 from "../../../assets/json/patterns/hebrew/chapter8.json";
import chapter9 from "../../../assets/json/patterns/hebrew/chapter9.json";
import chapter10 from "../../../assets/json/patterns/hebrew/chapter10.json";

// 1. 빌드 시 생성될 모든 경로를 정의합니다.
export async function getStaticPaths() {
  // 모든 레벨의 모든 챕터를 하나의 배열로 평탄화(flatten)하여 경로를 생성합니다.
  return chapters.map((chapter) => ({
    params: {
      path: chapter.path, // [path] 부분에 들어갈 값
    },
    props: { chapter },
  }));
}

// 2. 위에서 넘겨준 props를 받아옵니다.
const { path } = Astro.params;
const { chapter } = Astro.props;

// Chapter 지정
let jsonData;
switch (chapter.id) {
  case 1:
    jsonData = chapter1;
    break;
  case 2:
    jsonData = chapter2;
    break;
  case 3:
    jsonData = chapter3;
    break;
  case 4:
    jsonData = chapter4;
    break;
  case 5:
    jsonData = chapter5;
    break;
  case 6:
    jsonData = chapter6;
    break;
  case 7:
    jsonData = chapter7;
    break;
  case 8:
    jsonData = chapter8;
    break;
  case 9:
    jsonData = chapter9;
    break;
  case 10:
    jsonData = chapter10;
    break;
  default:
    jsonData = chapter1;
    break;
}
---

<IvriahLayout pageTitle={chapter.kor + " | Ivriah"}>
  <BoxFrontier2rtl title={chapter.heb} subtitle={chapter.kor} language="heb" />

  {
    jsonData.map((post: any) => (
      <ButtonFrontier2rtl
        id={post.id}
        title={post.pattern}
        subtitle={post.translation}
        language="heb"
        path={"/ivriah/pattern/" + path + "/" + post.id}
      />
    ))
  }
</IvriahLayout>
