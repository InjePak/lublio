---
import IvriahLayout from "../../../layouts/IvriahLayout.astro";
import BoxFrontier from "../../../components/BoxFrontier.astro";
import ButtonFrontier2rtl from "../../../components/ButtonFrontier2rtl.astro";

import chapters from "../../../assets/json/patterns/chapters.json";

const pageTitle = "Hebrew Sentence Patterns";
---

<IvriahLayout pageTitle={pageTitle + " | Ivriah"}>
  <BoxFrontier
    title="Tavniyot"
    subtitle="Sentence Patterns"
    description="Create tens of thousands of sentences using just a single pattern, without any complicated thinking. Experience the most efficient way to quickly improve your speaking skills."
    language="heb"
  />

  {
    chapters.map((post: any) => (
      <ButtonFrontier2rtl
        id={post.id}
        title={post.heb}
        subtitle={post.eng}
        language="heb"
        path={"/ivriah/pattern/" + post.path}
      />
    ))
  }
</IvriahLayout>
