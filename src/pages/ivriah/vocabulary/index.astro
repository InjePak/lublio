              id={post.id}
              title={post.heb}
              subtitle={post.eng}
              language="heb"
              path={"/ivriah/vocabulary/a2/" + post.path}
            />
          ))
        }
      </ul>
    </section> -->

    <!-- <section id="group-b1">
      <h2>
        <span class="animated-underline-heb">CEFR B1</span>
      </h2>
      <ul>
        {
          chapters_b1.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.heb}
              subtitle={post.eng}
              language="heb"
              path={"/ivriah/vocabulary/b1/" + post.path}
            />
          ))
        }
      </ul>
    </section> -->

    <!-- <section id="group-b2">
      <h2>
        <span class="animated-underline-heb">CEFR B2</span>
      </h2>
      <ul>
        {
          chapters_b2.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.heb}
              subtitle={post.eng}
              language="heb"
              path={"/ivriah/vocabulary/b2/" + post.path}
            />
          ))
        }
      </ul>
    </section> -->
  </main>
</Layout>

<style>
  section {
    padding-top: 1.5rem;
  }
</style>
