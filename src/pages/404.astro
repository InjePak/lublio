---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonMain from "../components/ButtonMain.astro";
import Typewriter from "../components/Typewriter.astro";

// Logo
import LogoSVG from "../../public/lublio-logo-light.svg?raw";

const pageTitle = "Lublio";
---

<BaseLayout pageTitle={pageTitle}>
  <div class="icon-wrapper">
    <a href="/">
      <Fragment set:html={LogoSVG} />
    </a>
  </div>
  <h1>404</h1>
  <h2>Not Found</h2>
</BaseLayout>

<style>
  .icon-wrapper {
    position: absolute;
    width: 60px; /* 원하는 크기 조절 */
    top: 40%;
    left: 50%;
    padding-top: 10px;
    padding-left: 10px;
    padding-right: 10px;
    padding-bottom: 5px;
    transform: translate(-50%, -50%);
    transition: 0.4s all;
  }

  /* SVG 내부의 path나 circle 등을 직접 제어 */
  .icon-wrapper :global(svg) {
    width: 100%;
    height: 100%;
  }

  /* 호버 시 색상 변경 예시 */
  .icon-wrapper:hover {
    cursor: pointer;
    background-color: var(--neutral200);
  }

  h1 {
    position: absolute;
    font-family: "Noto Korean", sans-serif;
    display: block;
    text-align: center;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 50px;
    line-height: 60px;
    margin-bottom: 1rem;
  }

  h2 {
    position: absolute;
    font-family: "Noto Korean", sans-serif;
    display: block;
    text-align: center;
    top: 62%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 18px;
    line-height: 26px;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .icon-wrapper {
      width: 50px; /* 원하는 크기 조절 */
      top: 42%;
    }

    h1 {
      font-size: 36px;
    }

    h2 {
      font-size: 16px;
      top: 60%;
    }
  }
</style>
