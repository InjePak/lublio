---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Box2 from "../../../components/Box2.astro";
import Button2 from "../../../components/Button2.astro";
import SectionSwitcher from "../../../components/SectionSwitcher.astro";

import chapters from "../../../assets/json/phrasebook/chapters.json";
const chapters_a1 = chapters["a1"];
const chapters_a2 = chapters["a2"];
const chapters_b1 = chapters["b1"];
const chapters_b2 = chapters["b2"];

// Title
const pageTitle = "튀르키예어 회화";

// Section Switcher
const tabItems = [
  { id: "group-a1", label: "A1 (입문)" },
  { id: "group-a2", label: "A2 (기초)" },
  { id: "group-b1", label: "B1 (중급)" },
  { id: "group-b2", label: "B2 (중고급)" },
];
---

<BaseLayout pageTitle={pageTitle + " | Lublio"}>
  <Box2
    title="튀르키예어 회화"
    subtitle="Cümleler"
    description="튀르크인과 손을 가슴에 얹으며 건네는 메르하바 — 두 대륙이 바다를 사이에 두고 마주 보는 곳, 말 한마디 한마디에 환대와 자부심이 함께 실리는 곳. 이 회화 모음집은 일상의 튀르키예어 깊숙이 흐르는 넉넉하고 힘 있는 결을 담았습니다."
    language="tur"
  />

  <SectionSwitcher items={tabItems} />

  <main>
    <section class="group-a1">
      <h2>
        <span class="animated-underline-tur">CEFR A1</span>
      </h2>
      <ul>
        {
          chapters_a1.map((post: any) => (
            <Button2
              id={post.id}
              title={post.kor}
              subtitle={post.tur}
              language="tur"
              path={"/turkish/phrasebook/a1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section class="group-a2">
      <h2>
        <span class="animated-underline-tur">CEFR A2</span>
      </h2>
      <ul>
        {
          chapters_a2.map((post: any) => (
            <Button2
              id={post.id}
              title={post.kor}
              subtitle={post.tur}
              language="tur"
              path={"/turkish/phrasebook/a2/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section class="group-b1">
      <h2>
        <span class="animated-underline-tur">CEFR B1</span>
      </h2>
      <ul>
        {
          chapters_b1.map((post: any) => (
            <Button2
              id={post.id}
              title={post.kor}
              subtitle={post.tur}
              language="tur"
              path={"/turkish/phrasebook/b1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section class="group-b2">
      <h2>
        <span class="animated-underline-tur">CEFR B2</span>
      </h2>
      <ul>
        {
          chapters_b2.map((post: any) => (
            <Button2
              id={post.id}
              title={post.kor}
              subtitle={post.tur}
              language="tur"
              path={"/turkish/phrasebook/b2/" + post.path}
            />
          ))
        }
      </ul>
    </section>
  </main>
</BaseLayout>

<style>
  section {
    padding-top: 1.5rem;
  }

  section > ul {
    display: grid;
    height: 100%;
    grid-template-columns: 1fr 1fr;
    justify-items: stretch;
    gap: 1.5rem;
    margin-bottom: 0rem;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const selectors = [
      ".animated-underline",
      ".animated-underline-eng",
      ".animated-underline-fra",
      ".animated-underline-deu",
      ".animated-underline-rus",
      ".animated-underline-tur",
      ".animated-underline-ita",
      ".animated-underline-heb",
      ".animated-underline-kaz",
    ];

    document.querySelectorAll(selectors.join(", ")).forEach((el) => {
      el.classList.add("is-active");
    });
  });
</script>
