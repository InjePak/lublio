---
import BaseLayout from "../layouts/BaseLayout.astro";
import Box from "../components/Box.astro";

import chapters from "../assets/json/phrasebook/chapters.json";
const chapters_a1 = chapters["a1"];
const chapters_a2 = chapters["a2"];
const chapters_b1 = chapters["b1"];
const chapters_b2 = chapters["b2"];

const artikel = Object.values(
  import.meta.glob("./german/artikel/*.md", { eager: true }),
);

const substantiv = Object.values(
  import.meta.glob("./german/substantiv/*.md", { eager: true }),
);

const pageTitle = "다개국어 회화";
---

<BaseLayout pageTitle={pageTitle + " | Lublio"}>
  <Box
    title="Multilingual Phrasebook"
    subtitle="다개국어 회화"
    description="Hic liber est clavis aurea mundi. Multas linguas continet ut variarum gentium mentes cognoscas et libere loquaris. Mundus totus in manibus tuis est."
  />

  <h2>
    <span class="animated-underline">CEFR A1</span>
  </h2>
  <ul>
    {
      chapters_a1.map((post: any) => (
        <li>
          <a href={"/phrasebook/a1/" + post.path}>
            {post.id}. {post.kor}
          </a>
        </li>
      ))
    }
  </ul>

  <hr />

  <h2>
    <span class="animated-underline">CEFR A2</span>
  </h2>
  <ul>
    {
      chapters_a2.map((post: any) => (
        <li>
          <a href={"/phrasebook/a2/" + post.path}>
            {post.id}. {post.kor}
          </a>
        </li>
      ))
    }
  </ul>

  <hr />

  <h2>
    <span class="animated-underline">CEFR B1</span>
  </h2>
  <ul>
    {
      chapters_b1.map((post: any) => (
        <li>
          <a href={"/phrasebook/b1/" + post.path}>
            {post.id}. {post.kor}
          </a>
        </li>
      ))
    }
  </ul>

  <hr />

  <h2>
    <span class="animated-underline">CEFR B2</span>
  </h2>
  <ul>
    {
      chapters_b2.map((post: any) => (
        <li>
          <a href={"/phrasebook/b2/" + post.path}>
            {post.id}. {post.kor}
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  li {
    display: block;
    width: 100%;
    border-radius: 10px;
    margin-bottom: 1.5rem;
  }

  li:last-child {
    margin-bottom: 0rem;
  }

  li > a {
    display: inline-block;
    width: 100%;
    padding: 1rem 1.5rem;
    border: 1px solid var(--zinc400);
    border-radius: 10px;
    font-weight: 500;
    color: var(--zinc800);
    transition: all 0.3s;
  }
  
  li > a:hover {
    background-color: var(--zinc300);
    border-radius: 25px;
    color: var(--zinc800);
  }
</style>
