---
import KazakhLayout from "../../../layouts/KazakhLayout.astro";
import BoxFrontier from "../../../components/BoxFrontier.astro";
import ButtonFrontier2 from "../../../components/ButtonFrontier2.astro";
import SectionSwitcherFrontier from "../../../components/SectionSwitcherFrontier.astro";

import chapters from "../../../assets/json/composite/chapters.json";
const chapters_a0 = chapters["a0"];
const chapters_a1 = chapters["a1"];
const chapters_a2 = chapters["a2"];
const chapters_b1 = chapters["b1"];

// Title
const pageTitle = "종합 카자흐어";

// Section Switcher
const tabItems = [
  { id: "group-a0", label: "입문" },
  { id: "group-a1", label: "기초" },
  { id: "group-a2", label: "초급" },
  { id: "group-b1", label: "중급" },
];
---

<KazakhLayout pageTitle={pageTitle + " | Lublio"}>
  <BoxFrontier
    title="Qazaqsha"
    subtitle="종합 카자흐어"
    description="알마티의 활기 속에서 건네는 부드러운 살렘 — 저 멀리 눈 덮인 텡리 산이 솟아오른 곳, 초원의 바람이 탁 트인 자유로움을 실어 나르는 곳. 이 회화 모음집은 일상의 카자흐어 깊은 곳에 흐르는 잔잔한 온기를 담았습니다."
    language="kaz"
  />

  <SectionSwitcherFrontier items={tabItems} />

  <main>
    <section class="group-a0 riseUp_2">
      <h2>
        <span class="animated-underline-kaz">입문 카자흐어 (A0)</span>
      </h2>
      <ul>
        {
          chapters_a0.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.kaz}
              subtitle={post.kor}
              language="kaz"
              path={"/kazakh/composite/a0/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section class="group-a1 riseUp_2">
      <h2>
        <span class="animated-underline-kaz">기초 카자흐어 (A1)</span>
      </h2>
      <ul>
        {
          chapters_a1.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.kaz}
              subtitle={post.kor}
              language="kaz"
              path={"/kazakh/composite/a1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section class="group-a2 riseUp_2">
      <h2>
        <span class="animated-underline-kaz">초급 카자흐어 (A2)</span>
      </h2>
      <ul>
        {
          chapters_a2.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.kaz}
              subtitle={post.kor}
              language="kaz"
              path={"/kazakh/composite/a2/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section class="group-b1 riseUp_2">
      <h2>
        <span class="animated-underline-kaz">중급 카자흐어 (B1)</span>
      </h2>
      <ul>
        {
          chapters_b1.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.kaz}
              subtitle={post.kor}
              language="kaz"
              path={"/kazakh/composite/b1/" + post.path}
            />
          ))
        }
      </ul>
    </section>
  </main>
</KazakhLayout>

<style>
  section {
    padding-top: 1.5rem;
  }
</style>
