---
import KazakhLayout from "../../../layouts/KazakhLayout.astro";
import BoxFrontier from "../../../components/BoxFrontier.astro";
import ButtonFrontier2 from "../../../components/ButtonFrontier2.astro";
import AnchorNavigationFrontier from "../../../components/AnchorNavigationFrontier.astro";

import chapters from "../../../assets/json/phrasebook/chapters.json";
const chapters_a1 = chapters["a1"];
// const chapters_a2 = chapters["a2"];
// const chapters_b1 = chapters["b1"];
// const chapters_b2 = chapters["b2"];

// Title
const pageTitle = "카자흐어 어휘";

// Anchor Navigation
const navItems = [
  { id: "group-a1", label: "A1" },
  { id: "group-a2", label: "A2" },
  { id: "group-b1", label: "B1" },
  { id: "group-b2", label: "B2" },
];
---

<KazakhLayout pageTitle={pageTitle + " | Kazariah"}>
  <BoxFrontier
    title="Sözdеr"
    subtitle="카자흐어 어휘"
    description="단어 하나가 문장을 바꿉니다. 알고 있는 단어가 늘어날수록 언어는 점점 내 것이 되어갑니다. 처음엔 낯설게 느껴지던 표현들이 어느 순간 자연스럽게 입에서 나오는 그 순간 — 그게 바로 진짜 실력이 쌓이는 순간입니다. 어휘를 넓혀가며 그 경험을 지금 시작해보세요."
    language="kaz"
  />

  <!-- <AnchorNavigationFrontier items={navItems} /> -->

  <main>
    <section id="group-a1">
      <h2>
        <span class="animated-underline-kaz">Basic Vocabulary</span>
      </h2>
      <ul>
        {
          chapters_a1.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.kaz}
              subtitle={post.eng}
              language="kaz"
              path={"/kazariah/vocabulary/a1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <!-- <section id="group-a2">
      <h2>
        <span class="animated-underline-kaz">CEFR A2</span>
      </h2>
      <ul>
        {
          chapters_a2.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.kaz}
              subtitle={post.eng}
              language="kaz"
              path={"/kazariah/vocabulary/a2/" + post.path}
            />
          ))
        }
      </ul>
    </section> -->

    <!-- <section id="group-b1">
      <h2>
        <span class="animated-underline-kaz">CEFR B1</span>
      </h2>
      <ul>
        {
          chapters_b1.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.kaz}
              subtitle={post.eng}
              language="kaz"
              path={"/kazariah/vocabulary/b1/" + post.path}
            />
          ))
        }
      </ul>
    </section> -->

    <!-- <section id="group-b2">
      <h2>
        <span class="animated-underline-kaz">CEFR B2</span>
      </h2>
      <ul>
        {
          chapters_b2.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.kaz}
              subtitle={post.eng}
              language="kaz"
              path={"/kazariah/vocabulary/b2/" + post.path}
            />
          ))
        }
      </ul>
    </section> -->
  </main>
</KazakhLayout>

<style>
  section {
    padding-top: 1.5rem;
  }
</style>
