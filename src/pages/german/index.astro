---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Box from "../../components/Box.astro";
import Button from "../../components/Button.astro";

const pageTitle = "German";
---

<BaseLayout pageTitle={pageTitle + " | Lublio"}>
  <Box
    title="Deutsch"
    subtitle="German"
    description="Deutsch ist die Sprache der Dichter und Denker. Als wichtige Wissenschafts- und Wirtschaftssprache in Europa überzeugt sie durch ihre logische Struktur und ihre Tiefe in Philosophie und Technik."
    language="deu"
  />

  <div class="button-wrapper">
    <!-- <Button
      title="Grammatik"
      subtitle="Grammar"
      description="CEFR A1 - B2"
      language="deu"
      path="/german/grammar"
      level="grammar"
      isDev="true"
    /> -->

    <Button
      title="Sätze"
      subtitle="Phrasebook"
      description="CEFR A1 - B2"
      language="deu"
      path="/german/phrasebook"
      level="phrase"
    />

    <Button
      title="Muster"
      subtitle="Sentence Patterns"
      description="CEFR B1 - C1"
      language="deu"
      path="/german/pattern"
      level="pattern"
    />

    <!-- <Button
      title="Wortschatz"
      subtitle="Vocabulary"
      description="CEFR A1 - C1"
      language="deu"
      path="/german/vocabulary"
      level="vocabulary"
      isDev="true"
    /> -->
  </div>
</BaseLayout>

<style>
  .button-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .button-wrapper {
      gap: 10px;
      margin-bottom: 10px;
    }
  }
</style>
