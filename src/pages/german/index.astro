---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BoxMain from "../../components/BoxMain.astro";
import Button from "../../components/Button.astro";

const pageTitle = "독일어";
---

<BaseLayout pageTitle={pageTitle + " | Lublio"}>
  <BoxMain
    title="독일어"
    subtitle="Deutsch"
    description="독일어는 사유의 언어입니다. 철학자들이 존재를 묻고, 엔지니어들이 세계를 설계하고, 시인들이 자연 앞에 경외를 표할 때, 독일어는 그 모든 무게를 정확하게 담아냈습니다. 엄밀하면서도 서정적인, 생각을 끝까지 밀어붙이게 만드는 언어, 지금 만나보세요."
    language="deu"
  />

  <div class="button-wrapper">
    <!-- <Button
      title="Grammatik"
      subtitle="Grammar"
      description="CEFR A1 - B2"
      language="deu"
      path="/german/grammar"
      level="grammar"
      isDev="true"
    /> -->

    <Button
      title="독일어 회화"
      subtitle="Sätze"
      description="CEFR A1 - B2"
      language="deu"
      path="/german/phrasebook"
      level="phrase"
    />

    <Button
      title="독일어 패턴"
      subtitle="Muster"
      description="CEFR B1 - C1"
      language="deu"
      path="/german/pattern"
      level="pattern"
    />

    <!-- <Button
      title="Wortschatz"
      subtitle="Vocabulary"
      description="CEFR A1 - C1"
      language="deu"
      path="/german/vocabulary"
      level="vocabulary"
      isDev="true"
    /> -->
  </div>
</BaseLayout>

<style>
  .button-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .button-wrapper {
      gap: 10px;
      margin-bottom: 10px;
    }
  }
</style>
