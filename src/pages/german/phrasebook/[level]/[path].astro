}
---

<BaseLayout pageTitle={chapter.kor + " | Lublio"}>
  <Box2 title={chapter.kor} subtitle={chapter.deu} language="deu" />

  <select id="lang-switcher">
    <option value="kor">한국어</option>
    <option value="eng">English</option>
    <option value="fra">Français</option>
    <option value="rus">Русский</option>
  </select>

  {
    !jsonData ? (
      <p>서버 에러입니다.</p>
    ) : (
      jsonData.map((data: any, index: number) => (
        <div class="phrase-box">
          <h1>{index + 1}</h1>
          <h2 lang="de">
            <img
              alt="Germany"
              src="https://purecatamphetamine.github.io/country-flag-icons/1x1/DE.svg"
            />
            {data.deu}
          </h2>
          <p
            class="translation"
            data-kor={data.kor}
            data-eng={data.eng}
            data-fra={data.fra}
            data-rus={data.rus}
          >
            {data.kor}
          </p>
        </div>
      ))
    )
  }
</BaseLayout>

<style>
  .phrase-box {
    margin-bottom: 2rem;
    padding: 2rem;
    border: 1px solid var(--neutral400);
    border-radius: 20px;
  }

  .phrase-box > h1 {
    text-align: left;
    width: 100%;
    color: var(--neutral700);
    padding: 0.5rem 0;
    padding-left: 0.5rem;
    font-family: "Inter", sans-serif;
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--neutral400);
  }

  .phrase-box > h2 {
    text-align: left;
    font-family: "Inter", sans-serif;
    font-size: 20px;
    font-weight: 500;
    hyphens: auto;
    overflow-wrap: break-word;
    margin-bottom: 0;
    color: var(--neutral700);
  }

  .phrase-box > h2 > img {
    display: inline-block;
    height: 18px;
    transform: translateY(2px);
    border-radius: 2px;
    margin-right: 0.5rem;
  }

  .phrase-box > p {
    text-align: left;
    font-size: 16px;
    margin-top: 1.5rem;
    margin-bottom: 1rem;
    line-height: 1rem;
    color: var(--neutral500);
  }

  .phrase-box > p > span {
    margin-right: 10px;
  }
</style>

<script>
  const translationSwitcher = document.getElementById(
    "lang-switcher",
  ) as HTMLSelectElement;
  const translations = document.querySelectorAll(".translation");

  translationSwitcher.addEventListener("change", () => {
    const lang = translationSwitcher.value;

    translations.forEach((el) => {
      const target = el as HTMLElement;
      target.textContent = target.dataset[lang] ?? "";
    });
  });
</script>
