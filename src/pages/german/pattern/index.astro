---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Box2 from "../../../components/Box2.astro";
import Button2 from "../../../components/Button2.astro";

import chapters from "../../../assets/json/patterns/chapters.json";

const pageTitle = "독일어";
---

<BaseLayout pageTitle={pageTitle + " | Lublio"}>
  <Box2
    title="독일어 패턴"
    subtitle="Redemittel"
    description="Deutsch ist die Sprache der Dichter und Denker. Als wichtige Wissenschafts- und Wirtschaftssprache in Europa überzeugt sie durch ihre logische Struktur und ihre Tiefe in Philosophie und Technik."
    language="deu"
  />

  {
    chapters.map((post: any) => (
      <Button2
        id={post.id}
        title={post.deu}
        subtitle={post.kor}
        language="deu"
        path={"/german/pattern/" + post.path}
      />
    ))
  }
</BaseLayout>
