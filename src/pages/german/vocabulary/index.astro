---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Box from "../../../components/Box.astro";
import Button2 from "../../../components/Button2.astro";

import chapters from "../../../assets/json/vocabulary/chapters.json";

const pageTitle = "German Vocabulary";
---

<BaseLayout pageTitle={pageTitle + " | Lublio"}>
  <Box
    title="Wortschatz"
    subtitle="Vocabulary"
    description="Words grouped the way your mind works — by theme, by context, by life. Build a vocabulary that's ready when the moment calls for it."
    language="deu"
  />

  {
    chapters.map((post: any) => (
      <Button2
        id={post.id}
        title={post.deu}
        subtitle={post.eng}
        language="deu"
        path={"/german/vocabulary/" + post.path}
      />
    ))
  }
</BaseLayout>
