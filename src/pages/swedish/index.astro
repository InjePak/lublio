---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Box from "../../components/Box.astro";
import Button from "../../components/Button.astro";

const pageTitle = "Swedish";
---

<BaseLayout pageTitle={pageTitle + " - Lublio"}>
  <Box
    title="Svenska"
    subtitle="Swedish"
    description="Svenska är språket för hisnande natur, tidlös design och filosofin om 'lagom'. Med sin melodiska klang och fokus på hållbarhet ger det tillgång till den innovativa skandinaviska kulturen och en värld där balans och enkelhet står i centrum."
    language="swe"
  />

  <div class="button-wrapper">
    <Button
      title="Fraser"
      subtitle="Phrasebook"
      description="CEFR A1 - B2"
      language="swe"
      path="/swedish/phrasebook"
      level="phrase"
    />

    <Button
      title="Mönster"
      subtitle="Patterns"
      description="CEFR B1 - C1"
      language="swe"
      path="/swedish/pattern"
      level="pattern"
    />

