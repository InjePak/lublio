---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Box from "../../components/Box.astro";
import Button from "../../components/Button.astro";

const pageTitle = "프랑스어";
---

<BaseLayout pageTitle={pageTitle + " - Lublio"}>
  <Box
    title="Français"
    subtitle="프랑스어"
    description="Le français est la langue de l'amour, de la gastronomie et de la diplomatie. Parlée sur cinq continents, elle se distingue par son élégance, sa richesse culturelle et sa précision analytique."
    language="fra"
  />

  <div class="button-wrapper">
    <Button
      title="Phrases"
      subtitle="프랑스어 회화"
      description="CEFR A1 - B2"
      language="fra"
      path="/french/phrasebook"
      level="phrase"
    />

    <Button
      title="Modèles"
      subtitle="프랑스어 패턴"
      description="CEFR B1 - C1"
      language="fra"
      path="/french/pattern"
      level="pattern"
    />

    <!-- <Button
      title="Franco"
      subtitle="모두의 프랑스어"
      description="CEFR A0 - B2"
      language="fra"
      path="/french/franco"
      level="composite"
      isDev="true"
    /> -->
  </div>

  <!-- <Button
    title="Grammaire"
    subtitle="프랑스어 문법"
    description="CEFR A1 - B2"
    language="fra"
    path="/french/grammar"
    level="grammar"
    isDev="true"
  /> -->
</BaseLayout>

<style>
  .button-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    justify-items: stretch;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .button-wrapper {
      gap: 10px;
      margin-bottom: 10px;
    }
  }
</style>
