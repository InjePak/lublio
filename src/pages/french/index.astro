---
import FrenchLayout from "../../layouts/FrenchLayout.astro";
import BoxMainFrontier from "../../components/BoxMainFrontier.astro";
import ButtonFrontier from "../../components/ButtonFrontier.astro";

const pageTitle = "프랑스어";
---

<FrenchLayout pageTitle={pageTitle + " | Lublio"}>
  <BoxMainFrontier
    title="Français"
    subtitle="프랑스어"
    description="프랑스어는 일상의 모든 순간을 예술로 만드는 언어입니다. 카페의 대화도, 시장의 흥정도, 낯선 이에게 건네는 인사도 프랑스어를 거치면 어딘가 다른 결을 띠게 됩니다. 삶을 조금 더 아름답게 바라보게 만드는 언어, 지금 만나보세요."
    language="fra"
  />

  <div class="buttonFrontier-wrapper">
    <!-- <ButtonFrontier
      title="Grammaire"
      subtitle="Grammar"
      description="CEFR A1 - B2"
      language="fra"
      path="/french/grammar"
      level="grammar"
      isDev="true"
    /> -->

    <ButtonFrontier
      title="Phrases"
      subtitle="프랑스어 회화"
      description="CEFR A1 - B2"
      language="fra"
      path="/french/phrasebook"
      level="phrase"
    />

    <ButtonFrontier
      title="Modèles"
      subtitle="프랑스어 패턴"
      description="CEFR B1 - C1"
      language="fra"
      path="/french/pattern"
      level="pattern"
    />

    <!-- <ButtonFrontier
      title="Vocabulaire"
      subtitle="Vocabulary"
      description="CEFR A1 - C1"
      language="fra"
      path="/french/vocabulary"
      level="vocabulary"
      isDev="true"
    /> -->
  </div>
</FrenchLayout>

<style>
  .buttonFrontier-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .buttonFrontier-wrapper {
      gap: 10px;
      margin-bottom: 10px;
    }
  }
</style>
