---
import FrenchLayout from "../../../layouts/FrenchLayout.astro";
import BoxFrontier from "../../../components/BoxFrontier.astro";
import ButtonFrontier2 from "../../../components/ButtonFrontier2.astro";
import SectionSwitcherFrontier from "../../../components/SectionSwitcherFrontier.astro";

import chapters from "../../../assets/json/phrasebook/chapters.json";
const chapters_a1 = chapters["a1"];
const chapters_a2 = chapters["a2"];
const chapters_b1 = chapters["b1"];
const chapters_b2 = chapters["b2"];

// Title
const pageTitle = "프랑스어 회화";

// Section Switcher
const tabItems = [
  { id: "group-a1", label: "A1" },
  { id: "group-a2", label: "A2" },
  { id: "group-b1", label: "B1" },
  { id: "group-b2", label: "B2" },
];
---

<FrenchLayout pageTitle={pageTitle + " | Lublio"}>
  <BoxFrontier
    title="Phrases"
    subtitle="프랑스어 회화"
    description="A lingering Salut, the clink of a wine glass, and the kind of small talk that somehow turns poetic. French is a language of mood and nuance — where every phrase carries a certain lightness, and even the simplest expression feels like it belongs in a film."
    language="fra"
  />

  <SectionSwitcherFrontier items={tabItems} />

  <main>
    <section class="group-a1">
      <h2>
        <span class="animated-underline-fra">CEFR A1</span>
      </h2>
      <ul>
        {
          chapters_a1.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.fra}
              subtitle={post.kor}
              language="fra"
              path={"/french/phrasebook/a1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section class="group-a2">
      <h2>
        <span class="animated-underline-fra">CEFR A2</span>
      </h2>
      <ul>
        {
          chapters_a2.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.fra}
              subtitle={post.kor}
              language="fra"
              path={"/french/phrasebook/a2/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section class="group-b1">
      <h2>
        <span class="animated-underline-fra">CEFR B1</span>
      </h2>
      <ul>
        {
          chapters_b1.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.fra}
              subtitle={post.kor}
              language="fra"
              path={"/french/phrasebook/b1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section class="group-b2">
      <h2>
        <span class="animated-underline-fra">CEFR B2</span>
      </h2>
      <ul>
        {
          chapters_b2.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.fra}
              subtitle={post.kor}
              language="fra"
              path={"/french/phrasebook/b2/" + post.path}
            />
          ))
        }
      </ul>
    </section>
  </main>
</FrenchLayout>

<style>
  section {
    padding-top: 1.5rem;
  }
</style>
