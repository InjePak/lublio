---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Box2 from "../../../components/Box2.astro";
import Button2 from "../../../components/Button2.astro";
import SectionSwitcher from "../../../components/SectionSwitcher.astro";

import chapters from "../../../assets/json/phrasebook/chapters.json";
const chapters_a1 = chapters["a1"];
const chapters_a2 = chapters["a2"];
const chapters_b1 = chapters["b1"];
const chapters_b2 = chapters["b2"];

// Title
const pageTitle = "프랑스어 회화";

// Section Switcher
const tabItems = [
  { id: "group-a1", label: "A1" },
  { id: "group-a2", label: "A2" },
  { id: "group-b1", label: "B1" },
  { id: "group-b2", label: "B2" },
];
---

<BaseLayout pageTitle={pageTitle + " | Lublio"}>
  <Box2
    title="프랑스어 회화"
    subtitle="Phrases"
    description="파리지앵과 눈이 마주치며 흘러나오는 살뤼 — 카페 테라스에 햇살이 비스듬히 내려앉는 곳, 말 한마디 한마디에 여유와 감각이 함께 실리는 곳. 이 회화 모음집은 일상의 프랑스어 깊숙이 흐르는 가볍고도 시적인 감성을 담았습니다."
    language="fra"
  />

  <SectionSwitcher items={tabItems} />

  <main>
    <section class="group-a1">
      <h2>
        <span class="animated-underline-fra">CEFR A1</span>
      </h2>
      <ul>
        {
          chapters_a1.map((post: any) => (
            <Button2
              id={post.id}
              title={post.kor}
              subtitle={post.fra}
              language="fra"
              path={"/french/phrasebook/a1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section class="group-a2">
      <h2>
        <span class="animated-underline-fra">CEFR A2</span>
      </h2>
      <ul>
        {
          chapters_a2.map((post: any) => (
            <Button2
              id={post.id}
              title={post.kor}
              subtitle={post.fra}
              language="fra"
              path={"/french/phrasebook/a2/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section class="group-b1">
      <h2>
        <span class="animated-underline-fra">CEFR B1</span>
      </h2>
      <ul>
        {
          chapters_b1.map((post: any) => (
            <Button2
              id={post.id}
              title={post.kor}
              subtitle={post.fra}
              language="fra"
              path={"/french/phrasebook/b1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section class="group-b2">
      <h2>
        <span class="animated-underline-fra">CEFR B2</span>
      </h2>
      <ul>
        {
          chapters_b2.map((post: any) => (
            <Button2
              id={post.id}
              title={post.kor}
              subtitle={post.fra}
              language="fra"
              path={"/french/phrasebook/b2/" + post.path}
            />
          ))
        }
      </ul>
    </section>
  </main>
</BaseLayout>

<style>
  section {
    padding-top: 1.5rem;
  }
</style>
