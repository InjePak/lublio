---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Box3 from "../../../components/Box3.astro";
import Button from "../../../components/Button.astro";

const pageTitle = "종합 프랑스어";
---

<BaseLayout pageTitle={pageTitle + " - Lublio"}>
  <Box3
    title="Franco"
    subtitle="종합 프랑스어"
    description="프랑스어는 미학적 섬세함과 논리적 엄밀함이 공존하는 지성의 언어입니다. 품격 있는 프랑코폰(Francophone)으로 거듭나는 지적 여정을 시작해볼까요?"
    language="fra"
  />

  <Button
    title="Débutant complet"
    subtitle="프랑스어 첫걸음"
    description="CEFR A0"
    language="fra"
    path="/french/franco/a0"
    level="a0"
    isDev="true"
  />

  <Button
    title="Débutant"
    subtitle="기초 프랑스어"
    description="CEFR A1"
    language="fra"
    path="/french/franco/a1"
    level="a1"
    isDev="true"
  />

  <Button
    title="Élémentaire"
    subtitle="초급 프랑스어"
    description="CEFR A2"
    language="fra"
    path="/french/franco/a2"
    level="a2"
    isDev="true"
  />

  <Button
    title="Intermédiaire"
    subtitle="중급 프랑스어"
    description="CEFR B1"
    language="fra"
    path="/french/franco/b1"
    level="b1"
    isDev="true"
  />

  <Button
    title="Intermédiaire supérieur"
    subtitle="중고급 프랑스어"
    description="CEFR B2"
    language="fra"
    path="/french/franco/b2"
    level="b2"
    isDev="true"
  />
</BaseLayout>
