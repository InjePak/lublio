---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Box2 from "../../../../components/Box2.astro";
import Button2 from "../../../../components/Button2.astro";

import chapters from "../../../../assets/json/a0/chapters.json";

const pageTitle = "프랑스어 첫걸음";
---

<BaseLayout pageTitle={pageTitle + " - Lublio"}>
  <Box2 title="Débutant complet" subtitle="프랑스어 첫걸음" language="fra" />

  {
    chapters.map((post: any) => (
      <Button2
        id={post.id}
        title={post.fra}
        subtitle={post.kor}
        language="fra"
        path={"/french/franco/a0/" + post.path}
      />
    ))
  }
</BaseLayout>
