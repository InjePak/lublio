---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import Box from "../../../components/Box.astro";
import Button2 from "../../../components/Button2.astro";
import AnchorNavigation from "../../../components/AnchorNavigation.astro";

const posts1 = await getCollection("grammar", ({ id }) => {
  return id.startsWith("french/nouns/");
});

const posts2 = await getCollection("grammar", ({ id }) => {
  return id.startsWith("french/pronouns/");
});

const posts3 = await getCollection("grammar", ({ id }) => {
  return id.startsWith("french/adjectives/");
});

const posts4 = await getCollection("grammar", ({ id }) => {
  return id.startsWith("french/verbs/");
});

const posts5 = await getCollection("grammar", ({ id }) => {
  return id.startsWith("french/prepositions/");
});

const posts6 = await getCollection("grammar", ({ id }) => {
  return id.startsWith("french/numerals/");
});

const posts7 = await getCollection("grammar", ({ id }) => {
  return id.startsWith("french/conjunctions/");
});

// Title
const pageTitle = "Russian Grammar";

// Anchor Navigation
const navItems = [
  { id: "group-nouns", label: "명사 & 관사" },
  { id: "group-pronouns", label: "대명사" },
  { id: "group-adjectives", label: "형용사 & 부사" },
  { id: "group-verbs", label: "동사" },
  { id: "group-prepositions", label: "전치사" },
  { id: "group-numerals", label: "수사" },
  { id: "group-conjunctions", label: "접속사 & 문장구조" },
];
---

<BaseLayout pageTitle={pageTitle + " - Lublio"}>
  <Box
    title="Грамматика"
    subtitle="Russian Grammar"
    description="The clearest roadmap for turning your thoughts into sentences. Build unwavering speaking skills on a rock-solid grammatical foundation."
    language="rus"
  />

  <AnchorNavigation items={navItems} />

  <main>
    <section id="group-nouns">
      <h2>
        <span class="animated-underline-fra">Ⅰ. 명사 &amp; 관사</span>
      </h2>
      <ul>
        {
          posts1.map((post: any, index: number) => {
            // URL 추출 로직
            // entry.id 예시: "french/nouns/basics.md" -> "nouns/basics"
            const slugWithoutLang = post.id
              .replace("french/", "")
              .replace(".md", "");

            const postUrl = `/french/grammar/${slugWithoutLang}`;

            return (
              <Button2
                id={index + 1}
                title={post.data.title}
                subtitle={post.data.translation}
                language="fra"
                path={postUrl}
              />
            );
          })
        }
      </ul>
    </section>

    <section id="group-pronouns">
      <h2>
        <span class="animated-underline-fra">Ⅱ. 대명사</span>
      </h2>
      <ul>
        {
          posts2.map((post: any, index: number) => {
