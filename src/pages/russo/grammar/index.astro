            const slugWithoutLang = post.id
              .replace("french/", "")
              .replace(".md", "");

            const postUrl = `/french/grammar/${slugWithoutLang}`;

            return (
              <Button2
                id={index + 1}
                title={post.data.title}
                subtitle={post.data.translation}
                language="fra"
