                id={index + 1}
                title={post.data.title}
                subtitle={post.data.translation}
                language="fra"
                path={postUrl}
              />
            );
          })
        }
      </ul>
    </section>

    <section id="group-adjectives">
      <h2>
        <span class="animated-underline-fra">Ⅲ. 형용사 &amp; 부사</span>
      </h2>
      <ul>
        {
          posts3.map((post: any, index: number) => {
            // URL 추출 로직
