            const postUrl = `/french/grammar/${slugWithoutLang}`;

            return (
              <Button2
                id={index + 1}
                title={post.data.title}
                subtitle={post.data.translation}
                language="fra"
                path={postUrl}
              />
            );
          })
        }
      </ul>
    </section>
  </main>
</BaseLayout>

<style>
  section {
    padding-top: 1.5rem;
  }
</style>
