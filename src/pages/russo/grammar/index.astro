      </ul>
    </section>

    <section id="group-conjunctions">
      <h2>
        <span class="animated-underline-fra">Ⅶ. 접속사 &amp; 문장구조</span>
      </h2>
      <ul>
        {
          posts7.map((post: any, index: number) => {
            // URL 추출 로직
            // entry.id 예시: "french/nouns/basics.md" -> "nouns/basics"
            const slugWithoutLang = post.id
              .replace("french/", "")
