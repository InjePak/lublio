---
import RussoLayout from "../../layouts/RussoLayout.astro";
import BoxMainFrontier from "../../components/BoxMainFrontier.astro";
import ButtonFrontier from "../../components/ButtonFrontier.astro";

const pageTitle = "Russo";
---

<RussoLayout pageTitle={pageTitle + " | Powered by Lublio"}>
  <BoxMainFrontier
    title="Russo"
    subtitle="Russian learning project"
    description="Русский — это язык великой литературы и космоса. Обладая невероятной силой выражения и эмоциональной глубиной, он открывает доступ к богатейшему культурному наследию и передовым научным достижениям."
    language="rus"
  />

  <div class="buttonFrontier-wrapper">
    <ButtonFrontier
      title="Фразы"
      subtitle="Phrasebook"
      description="CEFR A1 - B2"
      language="rus"
      path="/russo/phrasebook"
      level="phrase"
    />

    <ButtonFrontier
      title="Схемы"
      subtitle="Sentence Patterns"
      description="CEFR B1 - C1"
      language="rus"
      path="/russo/pattern"
      level="pattern"
    />

