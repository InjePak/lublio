---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Box from "../../../components/Box.astro";
import Button2 from "../../../components/Button2.astro";
import AnchorNavigation from "../../../components/AnchorNavigation.astro";

import chapters from "../../../assets/json/phrasebook/chapters.json";
const chapters_a1 = chapters["a1"];
const chapters_a2 = chapters["a2"];
const chapters_b1 = chapters["b1"];
const chapters_b2 = chapters["b2"];

// Title
const pageTitle = "Russian Phrasebook";

// Anchor Navigation
const navItems = [
  { id: "group-a1", label: "A1" },
  { id: "group-a2", label: "A2" },
  { id: "group-b1", label: "B1" },
  { id: "group-b2", label: "B2" },
];
---

<BaseLayout pageTitle={pageTitle + " - Lublio"}>
  <Box
    title="Russophone"
    subtitle="Russophone Studies"
    description="Centered on Russia as a critical Eurasian economic hub, this section explores the nation’s vast industrial capacity, energy sovereignty, and rapidly evolving digital economy. We examine the structural dynamics of the Russian market and its influence on regional trade blocks. By focusing on local talent pools, corporate governance, and investment trends, we provide a comprehensive understanding of the Russian business landscape and the economic resilience of the broader Russophone sphere."
    language="rus"
  />

  <AnchorNavigation items={navItems} />

  <main>
    <section id="group-a1">
      <h2>
        <span class="animated-underline-rus">CEFR A1</span>
      </h2>
      <ul>
        {
          chapters_a1.map((post: any) => (
            <Button2
              id={post.id}
              title={post.rus}
              subtitle={post.eng}
              language="rus"
              path={"/russo/phrasebook/a1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-a2">
      <h2>
        <span class="animated-underline-rus">CEFR A2</span>
      </h2>
      <ul>
        {
          chapters_a2.map((post: any) => (
            <Button2
              id={post.id}
              title={post.rus}
              subtitle={post.eng}
              language="rus"
              path={"/russo/phrasebook/a2/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-b1">
      <h2>
        <span class="animated-underline-rus">CEFR B1</span>
      </h2>
      <ul>
        {
          chapters_b1.map((post: any) => (
            <Button2
              id={post.id}
              title={post.rus}
              subtitle={post.eng}
              language="rus"
              path={"/russo/phrasebook/b1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-b2">
      <h2>
        <span class="animated-underline-rus">CEFR B2</span>
      </h2>
      <ul>
        {
          chapters_b2.map((post: any) => (
            <Button2
              id={post.id}
              title={post.rus}
              subtitle={post.eng}
              language="rus"
              path={"/russo/phrasebook/b2/" + post.path}
            />
          ))
        }
      </ul>
    </section>
  </main>
</BaseLayout>

<style>
  section {
    padding-top: 1.5rem;
  }
</style>
