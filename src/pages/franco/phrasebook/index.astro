---
import FrancoLayout from "../../../layouts/FrancoLayout.astro";
import BoxFrontier from "../../../components/BoxFrontier.astro";
import ButtonFrontier2 from "../../../components/ButtonFrontier2.astro";
import AnchorNavigationFrontier from "../../../components/AnchorNavigationFrontier.astro";

import chapters from "../../../assets/json/phrasebook/chapters.json";
const chapters_a1 = chapters["a1"];
const chapters_a2 = chapters["a2"];
const chapters_b1 = chapters["b1"];
const chapters_b2 = chapters["b2"];

// Title
const pageTitle = "French Phrasebook";

// Anchor Navigation
const navItems = [
  { id: "group-a1", label: "A1" },
  { id: "group-a2", label: "A2" },
  { id: "group-b1", label: "B1" },
  { id: "group-b2", label: "B2" },
];
---

<FrancoLayout pageTitle={pageTitle + " | Franco"}>
  <BoxFrontier
    title="Phrases"
    subtitle="French Phrasebook"
    description="A quiet café in Paris, the scent of espresso in the air, and a casual Salut exchanged between strangers. These are the expressions woven into the rhythm of Parisian life — effortlessly chic, unhurried, and full of the elegance that makes French such a beautiful language to speak."
    language="fra"
  />

  <AnchorNavigationFrontier items={navItems} />

  <main>
    <section id="group-a1">
      <h2>
        <span class="animated-underline-fra">CEFR A1</span>
      </h2>
      <ul>
        {
          chapters_a1.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.fra}
              subtitle={post.eng}
              language="fra"
              path={"/franco/phrasebook/a1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-a2">
      <h2>
        <span class="animated-underline-fra">CEFR A2</span>
      </h2>
      <ul>
        {
          chapters_a2.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.fra}
              subtitle={post.eng}
              language="fra"
              path={"/franco/phrasebook/a2/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-b1">
      <h2>
        <span class="animated-underline-fra">CEFR B1</span>
      </h2>
      <ul>
        {
          chapters_b1.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.fra}
              subtitle={post.eng}
              language="fra"
              path={"/franco/phrasebook/b1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-b2">
      <h2>
        <span class="animated-underline-fra">CEFR B2</span>
      </h2>
      <ul>
        {
          chapters_b2.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.fra}
              subtitle={post.eng}
              language="fra"
              path={"/franco/phrasebook/b2/" + post.path}
            />
          ))
        }
      </ul>
    </section>
  </main>
</FrancoLayout>

<style>
  section {
    padding-top: 1.5rem;
  }
</style>
