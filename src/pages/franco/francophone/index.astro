---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Box from "../../../components/Box.astro";
import Button2 from "../../../components/Button2.astro";
import AnchorNavigation from "../../../components/AnchorNavigation.astro";

import chapters from "../../../assets/json/phrasebook/chapters.json";
const chapters_a1 = chapters["a1"];
const chapters_a2 = chapters["a2"];
const chapters_b1 = chapters["b1"];
const chapters_b2 = chapters["b2"];

// Title
const pageTitle = "Francophone Studies";

// Anchor Navigation
const navItems = [
  { id: "group-a1", label: "A1" },
  { id: "group-a2", label: "A2" },
  { id: "group-b1", label: "B1" },
  { id: "group-b2", label: "B2" },
];
---

<BaseLayout pageTitle={pageTitle + " - Lublio"}>
  <Box
    title="Francophone"
    subtitle="Francophone Studies"
    description="This section provides a deep dive into France as a global economic powerhouse and the epicenter of the Francophone market. We analyze France’s leadership in high-tech industries, luxury goods, and green energy, alongside its role as a gateway to the European Union. Our focus extends to the strategic human resources and professional networks driving innovation and trade across the French-speaking world, offering a roadmap for navigating the complexities of its sophisticated business ecosystem."
    language="fra"
  />

  <AnchorNavigation items={navItems} />

  <main>
    <section id="group-a1">
      <h2>
        <span class="animated-underline-fra">CEFR A1</span>
      </h2>
      <ul>
        {
          chapters_a1.map((post: any) => (
            <Button2
              id={post.id}
              title={post.fra}
              subtitle={post.eng}
              language="fra"
              path={"/franco/phrasebook/a1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-a2">
      <h2>
        <span class="animated-underline-fra">CEFR A2</span>
      </h2>
      <ul>
        {
          chapters_a2.map((post: any) => (
            <Button2
              id={post.id}
              title={post.fra}
              subtitle={post.eng}
              language="fra"
              path={"/franco/phrasebook/a2/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-b1">
      <h2>
        <span class="animated-underline-fra">CEFR B1</span>
      </h2>
      <ul>
        {
          chapters_b1.map((post: any) => (
            <Button2
              id={post.id}
              title={post.fra}
              subtitle={post.eng}
              language="fra"
              path={"/franco/phrasebook/b1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-b2">
      <h2>
        <span class="animated-underline-fra">CEFR B2</span>
      </h2>
      <ul>
        {
          chapters_b2.map((post: any) => (
            <Button2
              id={post.id}
              title={post.fra}
              subtitle={post.eng}
              language="fra"
              path={"/franco/phrasebook/b2/" + post.path}
            />
          ))
        }
      </ul>
    </section>
  </main>
</BaseLayout>

<style>
  section {
    padding-top: 1.5rem;
  }
</style>
