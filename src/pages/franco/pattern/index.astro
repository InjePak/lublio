---
import FrancoLayout from "../../../layouts/FrancoLayout.astro";
import BoxFrontier from "../../../components/BoxFrontier.astro";
import ButtonFrontier2 from "../../../components/ButtonFrontier2.astro";

import chapters from "../../../assets/json/patterns/chapters.json";

const pageTitle = "French Sentence Patterns";
---

<FrancoLayout pageTitle={pageTitle + " - Lublio"}>
  <BoxFrontier
    title="Modèles"
    subtitle="French Sentence Patterns"
    description="Create tens of thousands of sentences with just one pattern, without complicated thinking. Experience the most efficient learning that gets you speaking quickly."
    language="fra"
  />

  {
    chapters.map((post: any) => (
      <ButtonFrontier2
        id={post.id}
        title={post.fra}
        subtitle={post.eng}
        language="fra"
        path={"/franco/pattern/" + post.path}
      />
    ))
  }
</FrancoLayout>
