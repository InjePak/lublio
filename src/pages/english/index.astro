---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BoxMain from "../../components/BoxMain.astro";
import Button from "../../components/Button.astro";

const pageTitle = "영어";
---

<BaseLayout pageTitle={pageTitle + " | Lublio"}>
  <BoxMain
    title="영어"
    subtitle="English"
    description="영어는 세계가 서로를 이해하기로 선택한 언어입니다. 뉴욕의 협상 테이블도, 런던의 펍 대화도, 뭄바이의 스타트업 피칭도 영어 위에서 만납니다. 어디서든 통하고, 누구와도 닿을 수 있는 언어, 지금 만나보세요."
    language="eng"
  />

  <div class="button-wrapper">
    <Button
      title="영어 회화"
      subtitle="Phrases"
      description="CEFR A1 - B2"
      language="eng"
      path="/english/phrasebook"
      level="phrase"
    />

    <Button
      title="영어 패턴"
      subtitle="Patterns"
      description="CEFR B1 - C1"
      language="eng"
      path="/english/pattern"
      level="pattern"
    />

    <!-- <Button
      title="종합 영어"
      subtitle="English"
      description="CEFR A1 - B2"
      language="eng"
      path="/english/composite"
      level="composite"
      isDev="true"
    /> -->

    <!-- <Button
      title="Словарь"
      subtitle="Vocabulary"
      description="CEFR A1 - C1"
      language="eng"
      path="/english/vocabulary"
      level="vocabulary"
      isDev="true"
    /> -->
  </div>
</BaseLayout>

<style>
  .button-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1rem;
    margin-top: 3rem;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .button-wrapper {
      gap: 10px;
      margin-bottom: 10px;
    }
  }
</style>
