---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Box from "../../../components/Box.astro";
import Button2 from "../../../components/Button2.astro";

import chapters from "../../../assets/json/patterns/chapters.json";

const pageTitle = "영어 패턴";
---

<BaseLayout pageTitle={pageTitle + " | Lublio"}>
  <Box
    title="Patterns"
    subtitle="영어 패턴"
    description="복잡한 고민 없이 패턴 하나로 수만 가지 문장을 만들어보세요. 가장 빠르게 말문이 트이는 효율적인 학습을 경험할 수 있습니다."
    language="eng"
  />

  {
    chapters.map((post: any) => (
      <Button2
        id={post.id}
        title={post.eng}
        subtitle={post.kor}
        language="eng"
        path={"/english/pattern/" + post.path}
      />
    ))
  }
</BaseLayout>
