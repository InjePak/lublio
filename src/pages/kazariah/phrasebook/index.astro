---
import Layout from "../../../layouts/KazariahLayout.astro";
import BoxFrontier from "../../../components/BoxFrontier.astro";
import ButtonFrontier2 from "../../../components/ButtonFrontier2.astro";
import AnchorNavigationFrontier from "../../../components/AnchorNavigationFrontier.astro";

import chapters from "../../../assets/json/phrasebook/chapters.json";
const chapters_a1 = chapters["a1"];
const chapters_a2 = chapters["a2"];
const chapters_b1 = chapters["b1"];
const chapters_b2 = chapters["b2"];

// Title
const pageTitle = "Kazakh Phrasebook";

// Anchor Navigation
const navItems = [
  { id: "group-a1", label: "A1" },
  { id: "group-a2", label: "A2" },
  { id: "group-b1", label: "B1" },
  { id: "group-b2", label: "B2" },
];
---

<Layout pageTitle={pageTitle + " | Kazariah"}>
  <BoxFrontier
    title="Tirkeser"
    subtitle="Kazakh Phrasebook"
    description="A gentle Sälem exchanged in the bustle of Almaty, with the snow-capped Tengri mountain rising in the distance — where steppe winds carry a sense of openness and ease. This phrasebook holds the quiet warmth at the heart of everyday Kazakh."
    language="kaz"
  />

  <AnchorNavigationFrontier items={navItems} />

  <main>
    <section id="group-a1">
      <h2>
        <span class="animated-underline-kaz">CEFR A1</span>
      </h2>
      <ul>
        {
          chapters_a1.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.kaz}
              subtitle={post.eng}
              language="kaz"
              path={"/kazariah/phrasebook/a1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-a2">
      <h2>
        <span class="animated-underline-kaz">CEFR A2</span>
      </h2>
      <ul>
        {
          chapters_a2.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.kaz}
              subtitle={post.eng}
              language="kaz"
              path={"/kazariah/phrasebook/a2/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-b1">
      <h2>
        <span class="animated-underline-kaz">CEFR B1</span>
      </h2>
      <ul>
        {
          chapters_b1.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.kaz}
              subtitle={post.eng}
              language="kaz"
              path={"/kazariah/phrasebook/b1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-b2">
      <h2>
        <span class="animated-underline-kaz">CEFR B2</span>
      </h2>
      <ul>
        {
          chapters_b2.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.kaz}
              subtitle={post.eng}
              language="kaz"
              path={"/kazariah/phrasebook/b2/" + post.path}
            />
          ))
        }
      </ul>
    </section>
  </main>
</Layout>

<style>
  section {
    padding-top: 1.5rem;
  }
</style>
