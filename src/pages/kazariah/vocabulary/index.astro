---
import KazariahLayout from "../../../layouts/KazariahLayout.astro";
import BoxFrontier from "../../../components/BoxFrontier.astro";
import ButtonFrontier2 from "../../../components/ButtonFrontier2.astro";
import AnchorNavigationFrontier from "../../../components/AnchorNavigationFrontier.astro";

import chapters from "../../../assets/json/phrasebook/chapters.json";
const chapters_a1 = chapters["a1"];
const chapters_a2 = chapters["a2"];
const chapters_b1 = chapters["b1"];
const chapters_b2 = chapters["b2"];

// Title
const pageTitle = "Kazakh Vocabulary";

// Anchor Navigation
const navItems = [
  { id: "group-a1", label: "A1" },
  { id: "group-a2", label: "A2" },
  { id: "group-b1", label: "B1" },
  { id: "group-b2", label: "B2" },
];
---

<KazariahLayout pageTitle={pageTitle + " | Kazariah"}>
  <BoxFrontier
    title="Sözdеr"
    subtitle="Kazakh Vocabulary"
    description="One word changes a sentence. The more vocabulary you build, the more the language becomes yours — start that experience now."
    language="kaz"
  />

  <!-- <AnchorNavigationFrontier items={navItems} /> -->

  <main>
    <section id="group-a1">
      <h2>
        <span class="animated-underline-kaz">Basic Vocabulary</span>
      </h2>
      <ul>
        {
          chapters_a1.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.kaz}
              subtitle={post.eng}
              language="kaz"
              path={"/kazariah/vocabulary/a1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <!-- <section id="group-a2">
