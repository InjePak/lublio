---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Box from "../../../components/Box.astro";
import Button2 from "../../../components/Button2.astro";
import AnchorNavigation from "../../../components/AnchorNavigation.astro";

import chapters from "../../../assets/json/phrasebook/chapters.json";
const chapters_a1 = chapters["a1"];
const chapters_a2 = chapters["a2"];
const chapters_b1 = chapters["b1"];
const chapters_b2 = chapters["b2"];

// Title
const pageTitle = "이탈리아어 회화";

// Anchor Navigation
const navItems = [
  { id: "group-a1", label: "A1" },
  { id: "group-a2", label: "A2" },
  { id: "group-b1", label: "B1" },
  { id: "group-b2", label: "B2" },
];
---

<BaseLayout pageTitle={pageTitle + " - Lublio"}>
  <Box
    title="Frasi"
    subtitle="이탈리아어 회화"
    description="로마의 햇살 아래 테라스에서 즐기는 에스프레소 한 잔의 여유. 현지의 낭만과 업무의 효율을 동시에 잡는 세련된 표현들을 학습해보세요."
    language="ita"
  />

  <AnchorNavigation items={navItems} />

  <main>
    <section id="group-a1">
      <h2>
        <span class="animated-underline-rus">CEFR A1</span>
      </h2>
      <ul>
        {
          chapters_a1.map((post: any) => (
            <Button2
              id={post.id}
              title={post.ita}
              subtitle={post.kor}
              language="ita"
              path={"/italian/phrasebook/a1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-a2">
      <h2>
        <span class="animated-underline-rus">CEFR A2</span>
      </h2>
      <ul>
        {
          chapters_a2.map((post: any) => (
            <Button2
              id={post.id}
              title={post.ita}
              subtitle={post.kor}
              language="ita"
              path={"/italian/phrasebook/a2/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-b1">
      <h2>
        <span class="animated-underline-rus">CEFR B1</span>
      </h2>
      <ul>
        {
          chapters_b1.map((post: any) => (
            <Button2
              id={post.id}
              title={post.ita}
              subtitle={post.kor}
              language="ita"
              path={"/italian/phrasebook/b1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-b2">
      <h2>
        <span class="animated-underline-rus">CEFR B2</span>
      </h2>
      <ul>
        {
          chapters_b2.map((post: any) => (
            <Button2
              id={post.id}
              title={post.ita}
              subtitle={post.kor}
              language="ita"
              path={"/italian/phrasebook/b2/" + post.path}
            />
          ))
        }
      </ul>
    </section>
  </main>
</BaseLayout>

<style>
  section {
    padding-top: 1.5rem;
  }
</style>
