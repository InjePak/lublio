---
import GermanoLayout from "../../../layouts/GermanoLayout.astro";
import BoxFrontier from "../../../components/BoxFrontier.astro";
import ButtonFrontier2 from "../../../components/ButtonFrontier2.astro";

import chapters from "../../../assets/json/patterns/chapters.json";

const pageTitle = "German Sentence Patterns";
---

<GermanoLayout pageTitle={pageTitle + " | Germano"}>
  <BoxFrontier
    title="Muster"
    subtitle="Sentence Patterns"
    description="Create tens of thousands of sentences using just a single pattern, without any complicated thinking. Experience the most efficient way to quickly improve your speaking skills."
    language="deu"
  />

  {
    chapters.map((post: any) => (
      <ButtonFrontier2
        id={post.id}
        title={post.deu}
        subtitle={post.eng}
        language="deu"
        path={"/germano/pattern/" + post.path}
      />
    ))
  }
</GermanoLayout>
