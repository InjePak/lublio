---
import GermanoLayout from "../../../layouts/GermanoLayout.astro";
import BoxFrontier from "../../../components/BoxFrontier.astro";
import ButtonFrontier2 from "../../../components/ButtonFrontier2.astro";
import AnchorNavigationFrontier from "../../../components/AnchorNavigationFrontier.astro";

import chapters from "../../../assets/json/phrasebook/chapters.json";
const chapters_a1 = chapters["a1"];
const chapters_a2 = chapters["a2"];
const chapters_b1 = chapters["b1"];
const chapters_b2 = chapters["b2"];

// Title
const pageTitle = "German Phrasebook";

// Anchor Navigation
const navItems = [
  { id: "group-a1", label: "A1" },
  { id: "group-a2", label: "A2" },
  { id: "group-b1", label: "B1" },
  { id: "group-b2", label: "B2" },
];
---

<GermanoLayout pageTitle={pageTitle + " | Germano"}>
  <BoxFrontier
    title="Sätze"
    subtitle="German Phrasebook"
    description="A firm handshake, a warm Hallo, and the kind of conversation that goes somewhere. German is a language of precision and depth — where every word earns its place, and every phrase carries the quiet confidence of a culture that takes ideas seriously."
    language="deu"
  />

  <AnchorNavigationFrontier items={navItems} />

  <main>
    <section id="group-a1">
      <h2>
        <span class="animated-underline-deu">CEFR A1</span>
      </h2>
      <ul>
        {
          chapters_a1.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.deu}
              subtitle={post.eng}
              language="deu"
              path={"/germano/phrasebook/a1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-a2">
      <h2>
        <span class="animated-underline-deu">CEFR A2</span>
      </h2>
      <ul>
        {
          chapters_a2.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.deu}
              subtitle={post.eng}
              language="deu"
              path={"/germano/phrasebook/a2/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-b1">
      <h2>
        <span class="animated-underline-deu">CEFR B1</span>
      </h2>
      <ul>
        {
          chapters_b1.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.deu}
              subtitle={post.eng}
              language="deu"
              path={"/germano/phrasebook/b1/" + post.path}
            />
          ))
        }
      </ul>
    </section>

    <section id="group-b2">
      <h2>
        <span class="animated-underline-deu">CEFR B2</span>
      </h2>
      <ul>
        {
          chapters_b2.map((post: any) => (
            <ButtonFrontier2
              id={post.id}
              title={post.deu}
              subtitle={post.eng}
              language="deu"
              path={"/germano/phrasebook/b2/" + post.path}
            />
          ))
        }
      </ul>
    </section>
  </main>
</GermanoLayout>

<style>
  section {
    padding-top: 1.5rem;
  }
</style>
