---
import GermanoLayout from "../../layouts/GermanoLayout.astro";
import BoxMainFrontier from "../../components/BoxMainFrontier.astro";
import ButtonFrontier from "../../components/ButtonFrontier.astro";

const pageTitle = "Germano";
---

<GermanoLayout pageTitle={pageTitle + " | Powered by Lublio"}>
  <BoxMainFrontier
    title="Germano"
    subtitle="German learning project"
    description="Deutsch ist die Sprache der Dichter und Denker. Als wichtige Wissenschafts- und Wirtschaftssprache in Europa überzeugt sie durch ihre logische Struktur und ihre Tiefe in Philosophie und Technik."
    language="deu"
  />

  <div class="buttonFrontier-wrapper">
    <ButtonFrontier
      title="Sätze"
      subtitle="Phrasebook"
      description="CEFR A1 - B2"
      language="deu"
      path="/germano/phrasebook"
      level="phrase"
    />

    <ButtonFrontier
      title="Muster"
      subtitle="Sentence Patterns"
      description="CEFR B1 - C1"
      language="deu"
      path="/germano/pattern"
      level="pattern"
    />

    <!-- <ButtonFrontier
      title="Germano"
      subtitle="모두의 독일어"
      description="CEFR A0 - B2"
      language="deu"
      path="/germano/germano"
      level="composite"
      isDev="true"
    /> -->
  </div>

  <!-- <ButtonFrontier
    title="Grammatik"
    subtitle="Grammar"
    description="CEFR A1 - B2"
    language="deu"
    path="/germano/grammar"
    level="grammar"
    isDev="true"
  /> -->
</GermanoLayout>

<style>
  .buttonFrontier-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  /* Mobile */
  @media (max-width: 480px) {
    .buttonFrontier-wrapper {
      gap: 10px;
      margin-bottom: 10px;
    }
  }
</style>
