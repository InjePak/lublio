---
import BaseLayout from "../../../layouts/BaseLayout.astro";

// src/pages/phrasebook/[level]/[path].astro
import chapters from "../../../assets/json/phrasebook/chapters.json";

// 1. 빌드 시 생성될 모든 경로를 정의합니다.
export async function getStaticPaths() {
  const levels = ["a1", "a2", "b1", "b2"] as const;

  // 모든 레벨의 모든 챕터를 하나의 배열로 평탄화(flatten)하여 경로를 생성합니다.
  return levels.flatMap((level) => {
    return chapters[level].map((chapter) => ({
      params: {
        level: level, // [level] 부분에 들어갈 값
        path: chapter.path, // [url] 부분에 들어갈 값
      },
      props: { chapter },
    }));
  });
}

// 2. 위에서 넘겨준 props를 받아옵니다.
const { level, path } = Astro.params;
const { chapter } = Astro.props;

// 3. 해당 레벨과 챕터에 맞는 데이터를 가져옵니다.
import phrase_a1_1 from "../../../assets/json/phrasebook/a1/phrase_a1_1.json";
