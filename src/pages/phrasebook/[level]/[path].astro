    break;
  default:
    jsonData = phrase_a1_1;
    break;
}

const pageTitle = "다개국어 회화";
---

<BaseLayout pageTitle={pageTitle + " | Lublio"}>
  <div class="title">
    <h1 class="riseUp_1">{chapter.kor}</h1>
    <hr />
    <p class="riseUp_2">{chapter.eng}</p>
    <p class="riseUp_3">{chapter.fra}</p>
    <p class="riseUp_4">{chapter.deu}</p>
    <p class="riseUp_5">{chapter.rus}</p>
  </div>

  <div class="controls">
    <label>
      <input
        type="checkbox"
        class="toggle-lang"
        data-target="phrase-eng"
        checked
      />
      <span>영어</span>
    </label>

    <label>
      <input
        type="checkbox"
        class="toggle-lang"
        data-target="phrase-deu"
        checked
      />
      <span>독일어</span>
    </label>

    <label>
      <input
        type="checkbox"
        class="toggle-lang"
        data-target="phrase-fra"
        checked
      />
      <span>프랑스어</span>
    </label>

    <label>
      <input
        type="checkbox"
        class="toggle-lang"
        data-target="phrase-rus"
        checked
      />
      <span>러시아어</span>
    </label>
  </div>

  {
    !jsonData ? (
      <p>서버 에러입니다.</p>
    ) : (
      jsonData.map((data: any, index: number) => (
        <div class="phrase-box">
          <h2>
            {index + 1}. {data.kor}
          </h2>
          <hr />
          <p class="phrase-eng">
            <span style="color: var(--pink400)">●</span>
            {data.eng}
          </p>
          <p class="phrase-deu">
            <span style="color: var(--amber400)">●</span>
            {data.deu}
          </p>
          <p class="phrase-fra">
            <span style="color: var(--sky400)">●</span>
            {data.fra}
          </p>
          <p class="phrase-rus">
            <span style="color: var(--indigo400)">●</span>
            {data.rus}
          </p>
        </div>
      ))
    )
  }

  <script>
    // 페이지 내의 모든 체크박스를 가져옵니다.
    const toggles = document.querySelectorAll(".toggle-lang");

    toggles.forEach((toggle) => {
      toggle.addEventListener("change", (e) => {
        const targetClass = (e.target as HTMLInputElement).dataset.target;
        const isVisible = (e.target as HTMLInputElement).checked;

        // 해당 클래스를 가진 모든 요소를 찾아 숨기거나 보입니다.
        const elements = document.querySelectorAll(`.${targetClass}`);
        elements.forEach((el) => {
          (el as HTMLElement).style.display = isVisible ? "block" : "none";
        });
      });
    });
  </script>
</BaseLayout>

<style>
  /* Title */

  .title {
    background-color: var(--zinc300);
    padding: 1.5rem 2rem;
    margin-bottom: 1.5rem;
    border-radius: 20px;
  }

  .title > h1,
  .title > p {
    width: 100%;
  }

  .title > h1 {
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .title > p {
    color: var(--zinc800);
    font-weight: 500;
    margin-bottom: 0rem;
  }

  .title > p:last-child {
    margin-bottom: 0;
  }

  .title > hr {
    border: 1px solid var(--zinc800);
    margin: 1.5rem 0;
  }

  /* Controls */

  .controls {
    /* position: sticky; */
    display: flex;
    justify-content: space-evenly;
    top: 0;
    background: var(--zinc800);
    padding: 0.5rem 1rem;
    display: flex;
    gap: 1rem;
    border-radius: 20px;
    margin-bottom: 1.5rem;
  }

  .controls label {
    cursor: pointer;
    font-size: 1rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .toggle-lang {
    display: none;
  }

  .toggle-lang + span {
    display: inline-block;
    padding: 8px 16px;
    background-color: var(--zinc800);
    color: var(--zinc200);
    border-radius: 50px;
    font-weight: 600;
    font-size: 16px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .toggle-lang:not(:checked) + span {
    color: var(--zinc200);
    opacity: 0.3;
  }

  .toggle-lang:not(:checked) + span:hover {
    background-color: var(--zinc700);
  }

  .toggle-lang:checked + span {
    color: var(--zinc200);
    opacity: 1;
  }

  .toggle-lang:checked + span:hover {
    background-color: var(--zinc700);
  }

  /* Phrase Box */

  .phrase-box {
    border: 1px solid var(--zinc400);
    border-radius: 20px;
    margin-bottom: 1.5rem;
    padding: 1.5rem;
  }

  .phrase-box > h2 {
    font-size: 20px;
    font-weight: 500;
    margin-top: 1rem;
  }

  .phrase-box > hr {
    border: 1px solid var(--zinc800);
    margin: 0;
    margin-bottom: 1.5rem;
  }

  .phrase-box > p {
    font-size: 16px;
    margin-bottom: 1rem;
  }

  .phrase-box > p > span {
    margin-right: 10px;
  }
</style>
