---
import "../styles/russian.css";
import HeaderFrontier from "../components/HeaderFrontier.astro";
import BackToTopFrontier from "../components/BackToTopFrontier.astro";

const { pageTitle } = Astro.props;

// Open Graph
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL("/og/lublio_russian_og.png", Astro.site);
const ogDescription =
  "러시아어는 대륙만큼 넓고 겨울만큼 깊은 언어입니다. 톨스토이와 도스토옙스키가 그 문장들로 인간의 내면을 파헤쳤고, 오늘날에도 유라시아 전역에서 수억 명의 목소리를 잇고 있습니다. 압도적인 스케일과 섬세함을 동시에 품은 언어, 지금 만나보세요.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta
      name="google-site-verification"
      content="IiN4hHkkW4C2wrQj5yc9yBKVdGODijd1Wx9qvyBxHbY"
    />
    <meta
      name="naver-site-verification"
      content="8447cb417472e2002c281e10833b348c5ce39c00"
    />
    <title>{pageTitle}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
  </head>
  <body>
    <div class="wrapper">
      <HeaderFrontier />
      <BackToTopFrontier />
      <slot />
    </div>
  </body>
</html>
